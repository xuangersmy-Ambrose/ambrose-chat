var currentMealType = 'breakfast';
var selectedFood = null;
var selectedQuantity = 1;

function showFoodSelector(mealType) {
  currentMealType = mealType || 'breakfast';
  var existing = document.getElementById('foodSelectorModal');
  if (existing) existing.remove();
  
  var totalCalories = userData.todayData.meals ? userData.todayData.meals.reduce(function(sum, m) { return sum + (m.calories || 0); }, 0) : 0;
  
  var html = '<div id="foodSelectorModal" style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.95); z-index: 100000; overflow-y: auto;">';
  html += '<div style="max-width: 500px; margin: 0 auto; padding: 24px;">';
  
  // 头部
  html += '<div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px;">';
  html += '<div><h3 style="font-size: 20px; margin-bottom: 4px;">🍽️ 记录饮食</h3>';
  html += '<p style="color: var(--text-secondary); font-size: 14px;">今日已摄入: ' + totalCalories + '千卡</p></div>';
  html += '<button onclick="closeFoodSelector()" style="background: none; border: none; color: var(--text-secondary); font-size: 24px; cursor: pointer;">✕</button>';
  html += '</div>';
  
  // 分类标签
  var categories = ['全部', '主食', '蛋白质', '蔬菜', '水果', '坚果', '零食', '饮品'];
  html += '<div style="display: flex; gap: 8px; overflow-x: auto; margin-bottom: 20px; padding-bottom: 8px;">';
  categories.forEach(function(cat, index) {
    var activeStyle = index === 0 ? 'background: var(--primary); color: #000;' : 'background: rgba(255,255,255,0.05); color: var(--text-secondary);';
    html += '<button onclick="filterFoodCategory(this, \'' + cat + '\')" style="padding: 8px 16px; border: none; border-radius: 20px; font-size: 14px; cursor: pointer; white-space: nowrap; ' + activeStyle + '">' + cat + '</button>';
  });
  html += '</div>';
  
  // 搜索框
  html += '<div style="margin-bottom: 20px;">';
  html += '<input type="text" id="foodSearchInput" placeholder="🔍 搜索食物..." oninput="searchFood(this.value)" style="width: 100%; padding: 16px; background: rgba(255,255,255,0.05); border: 1px solid var(--border); border-radius: 12px; color: #fff; font-size: 16px;">';
  html += '</div>';
  
  // 食物列表
  html += '<div id="foodListContainer">';
  html += renderFoodList(foodDatabase);
  html += '</div>';
  
  html += '</div></div>';
  
  document.body.insertAdjacentHTML('beforeend', html);
}

function renderFoodList(foods) {
  var html = '<div style="display: grid; gap: 12px;">';
  foods.forEach(function(food, index) {
    html += '<div onclick="showFoodDetail(' + index + ')" style="display: flex; align-items: center; padding: 16px; background: var(--bg-card); border: 1px solid var(--border); border-radius: 16px; cursor: pointer; transition: all 0.2s;">';
    html += '<div style="width: 48px; height: 48px; background: linear-gradient(135deg, rgba(0,212,255,0.2), rgba(255,45,146,0.2)); border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 24px; margin-right: 16px;">' + food.icon + '</div>';
    html += '<div style="flex: 1;">';
    html += '<div style="font-weight: 600; margin-bottom: 4px;">' + food.name + '</div>';
    html += '<div style="font-size: 13px; color: var(--text-secondary);">' + food.unit + '</div>';
    html += '</div>';
    html += '<div style="text-align: right;">';
    html += '<div style="font-weight: 700; color: var(--secondary);">' + food.calories + '</div>';
    html += '<div style="font-size: 12px; color: var(--text-secondary);">千卡</div>';
    html += '</div>';
    html += '</div>';
  });
  html += '</div>';
  return html;
}

function filterFoodCategory(btn, category) {
  // 更新按钮样式
  btn.parentElement.querySelectorAll('button').forEach(function(b) {
    b.style.background = 'rgba(255,255,255,0.05)';
    b.style.color = 'var(--text-secondary)';
  });
  btn.style.background = 'var(--primary)';
  btn.style.color = '#000';
  
  // 过滤食物
  var filtered = category === '全部' ? foodDatabase : foodDatabase.filter(function(f) { return f.category === category; });
  document.getElementById('foodListContainer').innerHTML = renderFoodList(filtered);
}

function searchFood(keyword) {
  if (!keyword) {
    document.getElementById('foodListContainer').innerHTML = renderFoodList(foodDatabase);
    return;
  }
  var filtered = foodDatabase.filter(function(f) { return f.name.includes(keyword); });
  document.getElementById('foodListContainer').innerHTML = renderFoodList(filtered);
}

function showFoodDetail(index) {
  selectedFood = foodDatabase[index];
  selectedQuantity = 1;
  
  var html = '<div id="foodDetailModal" style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.95); z-index: 100001; display: flex; align-items: center; justify-content: center; padding: 24px;">';
  html += '<div style="background: var(--bg-card); border: 1px solid var(--border); border-radius: 24px; padding: 32px 24px; width: 100%; max-width: 400px;">';
  
  // 食物信息
  html += '<div style="text-align: center; margin-bottom: 32px;">';
  html += '<div style="font-size: 64px; margin-bottom: 8px;">' + selectedFood.icon + '</div>';
  html += '<h3 style="font-size: 24px; margin-bottom: 4px;">' + selectedFood.name + '</h3>';
  html += '<p style="color: var(--text-secondary);">' + selectedFood.unit + '</p>';
  html += '<div style="font-size: 48px; font-weight: 700; color: var(--primary); margin-top: 16px;">' + selectedFood.calories + '<span style="font-size: 16px; color: var(--text-secondary);"> 千卡</span></div>';
  html += '</div>';
  
  // 数量选择
  html += '<div style="margin-bottom: 24px;">';
  html += '<label style="display: block; color: var(--text-secondary); font-size: 14px; margin-bottom: 12px; text-align: center;">选择数量</label>';
  html += '<div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px;">';
  [0.5, 1, 1.5, 2, 2.5, 3, 4, 5].forEach(function(qty) {
    var active = qty === 1 ? 'background: var(--primary); color: #000; border-color: var(--primary);' : 'background: rgba(255,255,255,0.05); color: #fff;';
    html += '<button onclick="selectFoodQuantity(this, ' + qty + ')" class="qty-btn" style="padding: 12px; border: 1px solid var(--border); border-radius: 12px; font-size: 14px; cursor: pointer; ' + active + '">' + qty + '</button>';
  });
  html += '</div>';
  html += '</div>';
  
  // 自定义数量
  html += '<div style="margin-bottom: 24px;">';
  html += '<label style="display: block; color: var(--text-secondary); font-size: 14px; margin-bottom: 8px;">自定义数量</label>';
  html += '<input type="number" id="customFoodQty" placeholder="输入数量" min="0.1" max="10" step="0.1" oninput="updateFoodCalories(this.value)" style="width: 100%; padding: 16px; background: rgba(255,255,255,0.05); border: 1px solid var(--border); border-radius: 12px; color: #fff; font-size: 16px; text-align: center;">';
  html += '</div>';
  
  // 预估热量
  html += '<div id="estimatedCalories" style="text-align: center; padding: 16px; background: rgba(0,212,255,0.1); border-radius: 12px; margin-bottom: 24px; font-size: 18px; font-weight: 600;">预计: ' + selectedFood.calories + ' 千卡</div>';
  
  // 按钮
  html += '<div style="display: flex; gap: 12px;">';
  html += '<button onclick="closeFoodDetail()" style="flex: 1; padding: 16px; background: transparent; border: 1px solid var(--border); border-radius: 12px; color: var(--text-secondary); font-size: 16px; cursor: pointer;">取消</button>';
  html += '<button onclick="addFoodRecord()" style="flex: 1; padding: 16px; background: var(--primary); border: none; border-radius: 12px; color: #000; font-weight: 600; font-size: 16px; cursor: pointer;">添加记录</button>';
  html += '</div>';
  
  html += '</div></div>';
  
  document.body.insertAdjacentHTML('beforeend', html);
}

function selectFoodQuantity(btn, qty) {
  selectedQuantity = qty;
  document.querySelectorAll('.qty-btn').forEach(function(b) {
    b.style.background = 'rgba(255,255,255,0.05)';
    b.style.color = '#fff';
    b.style.borderColor = 'var(--border)';
  });
  btn.style.background = 'var(--primary)';
  btn.style.color = '#000';
  btn.style.borderColor = 'var(--primary)';
  
  document.getElementById('customFoodQty').value = '';
  updateFoodCaloriesDisplay();
}

function updateFoodCalories(val) {
  if (val) {
    selectedQuantity = parseFloat(val);
    document.querySelectorAll('.qty-btn').forEach(function(b) {
      b.style.background = 'rgba(255,255,255,0.05)';
      b.style.color = '#fff';
    });
  }
  updateFoodCaloriesDisplay();
}

function updateFoodCaloriesDisplay() {
  var estimated = Math.round(selectedFood.calories * selectedQuantity);
  document.getElementById('estimatedCalories').textContent = '预计: ' + estimated + ' 千卡';
}

function addFoodRecord() {
  var customQty = document.getElementById('customFoodQty');
  var quantity = customQty && customQty.value ? parseFloat(customQty.value) : selectedQuantity;
  var calories = Math.round(selectedFood.calories * quantity);
  
  var meal = {
    type: currentMealType,
    food: selectedFood.name,
    quantity: quantity,
    unit: selectedFood.unit,
    calories: calories,
    time: new Date().toLocaleTimeString('zh-CN', { hour: '2-digit', minute: '2-digit' })
  };
  
  if (!userData.todayData.meals) userData.todayData.meals = [];
  userData.todayData.meals.push(meal);
  userData.todayData.calories = (userData.todayData.calories || 0) + calories;
  
  addPoints(30);
  saveData();
  updateHomePage();
  if (typeof updateDietPage === 'function') updateDietPage();
  
  // 检查任务完成
  var task = userData.tasks.find(function(t) { return t.id === 2; });
  if (task && !task.completed) completeTask(2);
  
  closeFoodDetail();
  closeFoodSelector();
  showToast('🍽️ 已添加 ' + selectedFood.name + ' +' + calories + '千卡 +30积分');
}

function closeFoodDetail() {
  var modal = document.getElementById('foodDetailModal');
  if (modal) modal.remove();
}

function closeFoodSelector() {
  var modal = document.getElementById('foodSelectorModal');
  if (modal) modal.remove();
}

// 旧版函数保留兼容
function addMeal(type) {
  showFoodSelector(type);
}

function updateDietPage() {
  var total = userData.todayData.meals.reduce((sum, m) => sum + m.calories, 0);
  document.getElementById('todayCalories').textContent = total;
  document.getElementById('proteinVal').textContent = Math.round(total * 0.25 / 4) + 'g';
  document.getElementById('carbVal').textContent = Math.round(total * 0.5 / 4) + 'g';
  document.getElementById('fatVal').textContent = Math.round(total * 0.25 / 9) + 'g';
}

// ==================== 成就页 ====================
function renderBadges() {
  var grid = document.getElementById('badgeGrid');
  var unlocked = badgeData.filter(b => userData.badges.includes(b.id)).length;
  document.getElementById('unlockedBadges').textContent = unlocked;
  
  var html = '';
  badgeData.forEach(badge => {
    var unlocked = userData.badges.includes(badge.id);
    var cls = unlocked ? 'unlocked' : 'locked';
    html += `
      <div class="badge-item ${cls}">
        <div class="badge-icon">${badge.icon}</div>
        <div class="badge-name">${badge.name}</div>
        <div class="badge-desc">${badge.desc}</div>
      </div>
    `;
  });
  grid.innerHTML = html;
}

// ==================== 个人资料 ====================
function updateProfilePage() {
  if (!currentUser) return;
  document.getElementById('profileName').textContent = currentUser.name;
  document.getElementById('profileInfo').textContent = 
    currentUser.age + '岁 | ' + currentUser.height + 'cm | ' + currentUser.weight + 'kg';
  document.getElementById('profileAvatar').textContent = currentUser.gender === 'male' ? '👨' : '👩';
  var bmi = (currentUser.weight / Math.pow(currentUser.height/100, 2)).toFixed(1);
  document.getElementById('profileBMI').textContent = bmi;
  var bmr = currentUser.gender === 'male' 
    ? Math.round(10 * currentUser.weight + 6.25 * currentUser.height - 5 * currentUser.age + 5)
    : Math.round(10 * currentUser.weight + 6.25 * currentUser.height - 5 * currentUser.age - 161);
  document.getElementById('profileBMR').textContent = bmr;
  var loginTime = localStorage.getItem('ambroseLoginTime');
  if (loginTime) {
    var days = Math.floor((Date.now() - parseInt(loginTime)) / (1000 * 60 * 60 * 24)) + 1;
    document.getElementById('profileDays').textContent = days;
  }
}

// ==================== 退出登录 ====================
function logout() {
  localStorage.removeItem('ambroseUser');
  currentUser = null;
  document.getElementById('bossCode').value = '';
  ['phoneInput', 'verifyCode', 'userName', 'userAge', 'userHeight', 'userWeight'].forEach(id => {
    var el = document.getElementById(id);
    if (el) el.value = '';
  });
  selectedGender = '';
  document.querySelectorAll('.gender-option').forEach(g => g.classList.remove('selected'));
  showPage('loginPage');
  switchMode('boss');
  document.getElementById('bottomNav').style.display = 'none';
  showToast('已退出登录');
}

