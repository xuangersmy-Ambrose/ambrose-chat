var challenges = [
  { id: 1, name: '21天腹肌挑战', participants: 1523, days: 21, reward: '🏅 腹肌徽章', joined: false, image: '💪' },
  { id: 2, name: '每日万步挑战', participants: 8921, days: 30, reward: '💎 500积分', joined: true, image: '👟' },
  { id: 3, name: '早起打卡挑战', participants: 3456, days: 7, reward: '🌅 早起鸟徽章', joined: false, image: '🌅' },
  { id: 4, name: '30天瑜伽挑战', participants: 2134, days: 30, reward: '🧘 瑜伽大师徽章', joined: false, image: '🧘' },
  { id: 5, name: '减脂大作战', participants: 5678, days: 14, reward: '🔥 1000积分', joined: false, image: '🔥' }
];

function showChallenges() {
  var html = '<div class="page" id="challengePage"><div class="workout-page">';
  html += '<div class="page-header"><div class="page-title">⚔️ 挑战赛</div><div class="page-subtitle">参与挑战，突破自我</div></div>';
  
  html += '<div style="padding: 0 24px;">';
  challenges.forEach(c => {
    var btnClass = c.joined ? 'btn-secondary' : 'btn-primary';
    var btnText = c.joined ? '已参加' : '立即参加';
    html += `<div style="background: var(--bg-card); border: 1px solid var(--border); border-radius: 20px; padding: 20px; margin-bottom: 16px; ${c.joined ? 'border-color: var(--primary);' : ''}">
      <div style="display: flex; align-items: center; margin-bottom: 16px;">
        <div style="font-size: 48px; margin-right: 16px;">${c.image}</div>
        <div style="flex: 1;">
          <div style="font-weight: 600; font-size: 18px; margin-bottom: 4px;">${c.name}</div>
          <div style="color: var(--text-secondary); font-size: 13px;">👥 ${c.participants}人参与 · ⏱️ ${c.days}天</div>
        </div>
      </div>
      <div style="background: rgba(255,215,0,0.1); border: 1px solid rgba(255,215,0,0.3); border-radius: 12px; padding: 12px; margin-bottom: 16px;">
        <div style="font-size: 13px; color: #FFD700;">🎁 完成奖励: ${c.reward}</div>
      </div>
      <button class="${btnClass}" onclick="joinChallenge(${c.id})" ${c.joined ? 'disabled' : ''}>${btnText}</button>
    </div>`;
  });
  html += '</div>';
  
  html += '<button class="btn-secondary" onclick="showPage(\'homePage\')" style="margin: 40px 24px;">← 返回首页</button>';
  html += '</div></div>';
  
  document.body.insertAdjacentHTML('beforeend', html);
  showPage('challengePage');
}

function joinChallenge(id) {
  var challenge = challenges.find(c => c.id === id);
  if (challenge && !challenge.joined) {
    challenge.joined = true;
    showToast('🎉 成功参加「' + challenge.name + '」');
    showChallenges();
  }
}

// ==================== 私信/关注系统 ====================
function showFollowSystem() {
  showToast('关注/私信功能已添加');
}

// ==================== 数据导出 ====================
function exportData() {
  var data = {
    user: currentUser,
    points: userData.totalPoints,
    level: userData.level,
    badges: userData.badges
  };
  var dataStr = JSON.stringify(data, null, 2);
  var blob = new Blob([dataStr], { type: 'application/json' });
  var url = URL.createObjectURL(blob);
  var a = document.createElement('a');
  a.href = url;
  a.download = 'ambrose_data_' + new Date().toISOString().split('T')[0] + '.json';
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
  URL.revokeObjectURL(url);
  showToast('📥 数据导出成功');
}

// ==================== 首次使用引导 ====================
var currentOnboardingStep = 1;

function checkOnboarding() {
  var hasSeenOnboarding = localStorage.getItem('hasSeenOnboarding');
  if (!hasSeenOnboarding) {
    showOnboarding();
  }
}

function showOnboarding() {
  var modal = document.getElementById('onboardingModal');
  if (modal) {
    modal.style.display = 'block';
  }
}

function nextOnboardingStep() {
  document.getElementById('onboardingStep' + currentOnboardingStep).style.display = 'none';
  document.getElementById('dot' + currentOnboardingStep).style.background = 'rgba(255,255,255,0.3)';
  currentOnboardingStep++;
  document.getElementById('onboardingStep' + currentOnboardingStep).style.display = 'block';
  document.getElementById('dot' + currentOnboardingStep).style.background = 'var(--primary)';
}

function completeOnboarding() {
  localStorage.setItem('hasSeenOnboarding', 'true');
  document.getElementById('onboardingModal').style.display = 'none';
  showToast('🎉 欢迎开始您的健康之旅！');
}

// ==================== 加载优化 ====================
function showSkeletonLoader() {
  var loader = document.getElementById('skeletonLoader');
  if (loader) loader.style.display = 'block';
}

function hideSkeletonLoader() {
  var loader = document.getElementById('skeletonLoader');
  if (loader) loader.style.display = 'none';
}

// 页面加载完成后检查引导
window.addEventListener('load', function() {
  setTimeout(hideSkeletonLoader, 500);
  checkOnboarding();
});

// ==================== 快速操作 ====================
function showQuickActions() {
  var existing = document.getElementById('quickActionsMenu');
  if (existing) {
    existing.remove();
    return;
  }
  
  var html = '<div id="quickActionsMenu" style="position: fixed; bottom: 170px; right: 20px; background: rgba(20,20,20,0.98); border: 1px solid rgba(255,255,255,0.1); border-radius: 16px; padding: 12px; z-index: 10000; backdrop-filter: blur(20px);">';
  html += '<div onclick="showPage(\'workoutPage\'); closeQuickActions();" style="display: flex; align-items: center; gap: 12px; padding: 12px 16px; cursor: pointer; border-radius: 12px; margin-bottom: 4px;"><span style="font-size: 20px;">💪</span><span style="font-size: 14px;">开始训练</span></div>';
  html += '<div onclick="showPage(\'dietPage\'); closeQuickActions();" style="display: flex; align-items: center; gap: 12px; padding: 12px 16px; cursor: pointer; border-radius: 12px; margin-bottom: 4px;"><span style="font-size: 20px;">🍽️</span><span style="font-size: 14px;">记录饮食</span></div>';
  html += '<div onclick="showToast(\'AI教练即将开放\'); closeQuickActions();" style="display: flex; align-items: center; gap: 12px; padding: 12px 16px; cursor: pointer; border-radius: 12px;"><span style="font-size: 20px;">🤖</span><span style="font-size: 14px;">AI教练</span></div>';
  html += '</div>';
  
  var div = document.createElement('div');
  div.innerHTML = html;
  document.body.appendChild(div);
}

function closeQuickActions() {
  var menu = document.getElementById('quickActionsMenu');
  if (menu) menu.remove();
}

