<!-- 首次使用引导 -->
<div id="onboardingModal" style="display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.95); z-index: 100000; padding: 40px 24px;">
  <div style="max-width: 400px; margin: 0 auto; text-align: center;">
    <div id="onboardingStep1">
      <div style="font-size: 80px; margin-bottom: 24px;">🏋️</div>
      <h2 style="font-size: 24px; margin-bottom: 16px;">欢迎来到 AMBROSE</h2>
      <p style="color: var(--text-secondary); margin-bottom: 32px; line-height: 1.6;">您的AI健康教练，帮助您科学健身、管理健康</p>
      <button class="btn-primary" onclick="nextOnboardingStep()">开始了解</button>
    </div>
    <div id="onboardingStep2" style="display: none;">
      <div style="font-size: 80px; margin-bottom: 24px;">🤖</div>
      <h2 style="font-size: 24px; margin-bottom: 16px;">AI智能教练</h2>
      <p style="color: var(--text-secondary); margin-bottom: 32px; line-height: 1.6;">随时随地咨询健身问题，获取个性化训练建议</p>
      <button class="btn-primary" onclick="nextOnboardingStep()">下一步</button>
    </div>
    <div id="onboardingStep3" style="display: none;">
      <div style="font-size: 80px; margin-bottom: 24px;">📊</div>
      <h2 style="font-size: 24px; margin-bottom: 16px;">追踪您的进步</h2>
      <p style="color: var(--text-secondary); margin-bottom: 32px; line-height: 1.6;">记录训练、饮食、睡眠，见证每一天的改变</p>
      <button class="btn-primary" onclick="completeOnboarding()">开始使用</button>
    </div>
    <div style="display: flex; justify-content: center; gap: 8px; margin-top: 32px;">
      <span id="dot1" style="width: 8px; height: 8px; background: var(--primary); border-radius: 50%;"></span>
      <span id="dot2" style="width: 8px; height: 8px; background: rgba(255,255,255,0.3); border-radius: 50%;"></span>
      <span id="dot3" style="width: 8px; height: 8px; background: rgba(255,255,255,0.3); border-radius: 50%;"></span>
    </div>
  </div>
</div>

<!-- 加载优化 - 骨架屏 -->
<div id="skeletonLoader" style="display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: var(--bg-dark); z-index: 99999; padding: 24px;">
  <div style="max-width: 400px; margin: 0 auto;">
    <div style="height: 200px; background: rgba(255,255,255,0.05); border-radius: 20px; margin-bottom: 20px; animation: pulse 1.5s infinite;"></div>
    <div style="height: 100px; background: rgba(255,255,255,0.05); border-radius: 16px; margin-bottom: 16px; animation: pulse 1.5s infinite 0.2s;"></div>
    <div style="height: 100px; background: rgba(255,255,255,0.05); border-radius: 16px; margin-bottom: 16px; animation: pulse 1.5s infinite 0.4s;"></div>
    <div style="height: 100px; background: rgba(255,255,255,0.05); border-radius: 16px; animation: pulse 1.5s infinite 0.6s;"></div>
  </div>
</div>

