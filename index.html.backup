<!-- ========== 底部导航 ========== -->
<div class="bottom-nav" id="bottomNav" style="display: none;">
<div class="nav-item active" onclick="switchTab('home')" id="navHome">
<span class="icon">🏠</span>
<span class="text">首页</span>
</div>
<div class="nav-item" onclick="switchTab('workout')" id="navWorkout">
<span class="icon">💪</span>
<span class="text">训练</span>
</div>
<div class="nav-item" onclick="switchTab('diet')" id="navDiet">
<span class="icon">🥗</span>
<span class="text">饮食</span>
</div>
<div class="nav-item" onclick="switchTab('chat')" id="navChat">
<span class="icon">💬</span>
<span class="text">对话</span>
</div>
<div class="nav-item" onclick="switchTab('profile')" id="navProfile">
<span class="icon">👤</span>
<span class="text">我的</span>
</div>
</div>

<script>
// ==================== 全局状态 ====================
var currentUser = null;
var userData = {
  points: 350,
  totalPoints: 350,
  level: 1,
  levelName: '健身新手',
  streak: 3,
  badges: ['first_workout', 'water_master', 'early_bird', 'calorie_tracker', 'step_beginner'],
  signinDays: [true, true, true, false, false, false, false],
  lastCheckDate: null,
  todayData: { water: 0, steps: 0, calories: 0, sleep: 0, meals: [] },
  tasks: [
    { id: 1, name: '完成一次训练', reward: '+50积分', completed: false, icon: '💪' },
    { id: 2, name: '记录今日饮食', reward: '+30积分', completed: false, icon: '🥗' },
    { id: 3, name: '喝水2000ml', reward: '+20积分', completed: false, icon: '💧' },
    { id: 4, name: '步数达到10000', reward: '+30积分', completed: false, icon: '👟' }
  ]
};
var workoutTimer = null, workoutSeconds = 0, workoutRunning = false;
var currentWorkout = { name: '', duration: 0, calories: 0 };

// ==================== 徽章数据 ====================
var badgeData = [
  { id: 'first_workout', name: '初次训练', desc: '完成第一次训练', icon: '🏃', unlocked: true },
  { id: 'water_master', name: '水分达人', desc: '连续7天喝水达标', icon: '💧', unlocked: true },
  { id: 'early_bird', name: '早起鸟', desc: '连续3天早8点前打卡', icon: '🌅', unlocked: true },
  { id: 'calorie_tracker', name: '卡路里记录', desc: '记录一周饮食', icon: '📝', unlocked: true },
  { id: 'step_beginner', name: '万步新手', desc: '单日步数破万', icon: '👟', unlocked: true },
  { id: 'week_warrior', name: '周战士', desc: '连续训练7天', icon: '🔥', unlocked: false },
  { id: 'month_master', name: '月度大师', desc: '坚持30天', icon: '📅', unlocked: false },
  { id: 'hiit_king', name: 'HIIT王者', desc: '完成50次HIIT', icon: '⚡', unlocked: false },
  { id: 'yoga_lover', name: '瑜伽爱好者', desc: '完成20次瑜伽', icon: '🧘', unlocked: false },
  { id: 'strength_beast', name: '力量野兽', desc: '深蹲1000次', icon: '🏋️', unlocked: false },
  { id: 'night_owl', name: '夜猫子', desc: '晚10点后训练', icon: '🦉', unlocked: false },
  { id: 'balanced_diet', name: '均衡饮食', desc: '一周营养均衡', icon: '🥗', unlocked: false }
];

// ==================== 页面切换（简化版） ====================
function showPage(pageId) {
  console.log('[DEBUG] showPage called with:', pageId);
  try {
    var pages = document.querySelectorAll('.page');
    console.log('[DEBUG] Found pages:', pages.length);
    pages.forEach(p => p.classList.remove('active'));
    
    var targetPage = document.getElementById(pageId);
    console.log('[DEBUG] Target page:', targetPage ? 'found' : 'NOT FOUND');
    
    if (targetPage) {
      targetPage.classList.add('active');
      console.log('[DEBUG] Page activated:', pageId);
    } else {
      console.error('[DEBUG] Page not found:', pageId);
      alert('页面加载失败，请刷新重试');
    }
    window.scrollTo(0, 0);
    
    var navPages = ['homePage', 'workoutPage', 'dietPage', 'chatPage', 'profilePage', 'communityPage', 'reportPage', 'coursePage'];
    var bottomNav = document.getElementById('bottomNav');
    if (bottomNav) bottomNav.style.display = navPages.includes(pageId) ? 'flex' : 'none';
    
    if (pageId === 'homePage' && typeof updateHomePage === 'function') updateHomePage();
    if (pageId === 'profilePage' && typeof updateProfilePage === 'function') updateProfilePage();
    if (pageId === 'achievePage' && typeof renderBadges === 'function') renderBadges();
    if (pageId === 'weightPage' && typeof updateWeightPage === 'function') updateWeightPage();
  } catch (e) {
    console.error('页面切换失败:', e);
  }
}

function updateNav(activeId) {
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  var activeNav = document.getElementById(activeId);
  if (activeNav) activeNav.classList.add('active');
}

function switchTab(tab) {
  if (tab === 'home') showPage('homePage');
  if (tab === 'workout') showPage('workoutPage');
  if (tab === 'diet') showPage('dietPage');
  if (tab === 'chat') showPage('chatPage');
  if (tab === 'profile') showPage('profilePage');
  
  // 更新导航状态
  document.querySelectorAll('.nav-item').forEach(el => el.classList.remove('active'));
  var navMap = { 'home': 'navHome', 'workout': 'navWorkout', 'diet': 'navDiet', 'chat': 'navChat', 'profile': 'navProfile' };
  var navEl = document.getElementById(navMap[tab]);
  if (navEl) navEl.classList.add('active');
}

function selectSleepQuality(quality) {
  document.querySelectorAll('#qualityGood, #qualityNormal, #qualityBad').forEach(el => el.classList.remove('selected'));
  document.getElementById('quality' + quality.charAt(0).toUpperCase() + quality.slice(1)).classList.add('selected');
}

var selectedQuality = '';
function selectSleepQuality(quality) {
  selectedQuality = quality;
  ['qualityGood', 'qualityNormal', 'qualityBad'].forEach(id => {
    var el = document.getElementById(id);
    if (el) el.classList.remove('selected');
  });
  var el = document.getElementById('quality' + quality.charAt(0).toUpperCase() + quality.slice(1));
  if (el) el.classList.add('selected');
}

function recordSleep() {
  var hours = parseFloat(document.getElementById('sleepHours').value);
  if (!hours || hours <= 0) { showToast('请输入睡眠时长'); return; }
  if (!selectedQuality) { showToast('请选择睡眠质量'); return; }
  userData.todayData.sleep = hours;
  var score = selectedQuality === 'good' ? 85 + Math.random() * 10 : selectedQuality === 'normal' ? 70 + Math.random() * 10 : 50 + Math.random() * 15;
  addPoints(15);
  saveData();
  showToast('😴 睡眠记录已保存 +15积分');
  showPage('homePage');
  updateHomePage();
}

function recordWeight() {
  var weight = parseFloat(document.getElementById('newWeightInput').value);
  if (!weight || weight <= 0) { showToast('请输入体重'); return; }
  if (!currentUser.weightHistory) currentUser.weightHistory = [];
  currentUser.weightHistory.push({ date: new Date().toISOString(), weight: weight });
  currentUser.weight = weight;
  addPoints(10);
  saveData();
  updateWeightPage();
  showToast('⚖️ 体重记录已保存 +10积分');
}

function updateWeightPage() {
  if (!currentUser) return;
  document.getElementById('currentWeight').textContent = currentUser.weight || '--';
  var history = currentUser.weightHistory || [];
  var start = history.length > 0 ? history[0].weight : currentUser.weight;
  document.getElementById('startWeight').textContent = start || '--';
  var change = history.length > 1 ? (currentUser.weight - history[0].weight).toFixed(1) : '0';
  var changeEl = document.getElementById('weightChange');
  changeEl.textContent = (change > 0 ? '+' : '') + change;
  changeEl.style.color = change <= 0 ? '#30D158' : '#FF6B6B';
  document.getElementById('targetWeight').textContent = (currentUser.weight ? (currentUser.weight - 5) : '--');
  renderWeightChart();
}

function renderWeightChart() {
  var chart = document.getElementById('weightChart');
  var history = currentUser.weightHistory || [{weight: currentUser.weight}, {weight: currentUser.weight * 0.99}, {weight: currentUser.weight * 0.98}, {weight: currentUser.weight * 0.98}, {weight: currentUser.weight * 0.97}, {weight: currentUser.weight * 0.97}, {weight: currentUser.weight * 0.96}];
  var weights = history.slice(-7).map(h => h.weight || currentUser.weight);
  var min = Math.min(...weights), max = Math.max(...weights);
  var range = max - min || 1;
  chart.innerHTML = weights.map(w => {
    var height = ((w - min) / range * 60 + 20);
    return `<div style="width: 30px; height: ${height}%; background: linear-gradient(to top, var(--primary), var(--secondary)); border-radius: 4px 4px 0 0; position: relative;"><span style="position: absolute; top: -20px; left: 50%; transform: translateX(-50%); font-size: 10px; color: var(--text-secondary);">${w.toFixed(1)}</span></div>`;
  }).join('');
}

function toggleSetting(el, id) {
  var toggle = document.getElementById(id);
  var isOn = toggle.style.background === 'var(--primary)' || getComputedStyle(toggle).backgroundColor === 'rgb(0, 212, 255)';
  toggle.style.background = isOn ? 'var(--border)' : 'var(--primary)';
  var knob = toggle.querySelector('div');
  knob.style.left = isOn ? '2px' : 'auto';
  knob.style.right = isOn ? 'auto' : '2px';
  showToast((isOn ? '已关闭' : '已开启') + '提醒');
}

// ==================== Toast ====================
function showToast(msg) {
  var t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2000);
}

// ==================== 签到系统 ====================
function showSigninModal() {
  var modal = document.getElementById('signinModal');
  modal.classList.add('show');
  renderSigninGrid();
}

function closeSignin() {
  document.getElementById('signinModal').classList.remove('show');
}

function renderSigninGrid() {
  var grid = document.getElementById('signinGrid');
  var rewards = [20, 30, 40, 50, 60, 80, 100];
  var days = ['周一', '周二', '周三', '周四', '周五', '周六', '周日'];
  var html = '';
  for (var i = 0; i < 7; i++) {
    var cls = userData.signinDays[i] ? 'completed' : (i === userData.streak ? 'active' : '');
    html += `
      <div class="signin-day ${cls}">
        <div class="day-label">${days[i]}</div>
        <div class="day-icon">${userData.signinDays[i] ? '✅' : '🎁'}</div>
        <div class="day-points">+${rewards[i]}</div>
      </div>
    `;
  }
  grid.innerHTML = html;
}

function doSignin() {
  if (userData.signinDays[userData.streak]) {
    showToast('今日已签到');
    return;
  }
  userData.signinDays[userData.streak] = true;
  userData.streak++;
  var rewards = [20, 30, 40, 50, 60, 80, 100];
  var points = rewards[userData.streak - 1] || 50;
  addPoints(points);
  showToast('🎉 签到成功！+' + points + '积分');
  closeSignin();
  updateHomePage();
}

// ==================== 登录系统 ====================
function switchMode(mode) {
  document.querySelectorAll('.mode-btn').forEach(b => b.classList.remove('active'));
  document.querySelectorAll('.login-form').forEach(f => f.classList.remove('active'));
  if (mode === 'boss') {
    document.getElementById('bossModeBtn').classList.add('active');
    document.getElementById('bossForm').classList.add('active');
  } else {
    document.getElementById('userModeBtn').classList.add('active');
    document.getElementById('userForm').classList.add('active');
  }
}

function loginBoss() {
  var code = document.getElementById('bossCode').value;
  if (code !== '0812') { showToast('识别码错误'); return; }
  currentUser = { type: 'boss', name: 'BOSS Shao', gender: 'male', age: 25, height: 175, weight: 70 };
  saveUserAndGoHome();
  showToast('👑 欢迎BOSS');
}

var selectedGender = '';
function selectGender(gender) {
  selectedGender = gender;
  document.querySelectorAll('.gender-option').forEach(g => g.classList.remove('selected'));
  document.getElementById('gender' + (gender === 'male' ? 'Male' : 'Female')).classList.add('selected');
}

function sendVerifyCode() {
  var phone = document.getElementById('phoneInput').value;
  if (phone.length !== 11) { showToast('请输入正确的手机号'); return; }
  showToast('验证码已发送: 123456');
  var btn = document.getElementById('sendCodeBtn');
  var count = 60;
  btn.disabled = true;
  btn.textContent = count + 's';
  var timer = setInterval(() => {
    count--;
    btn.textContent = count + 's';
    if (count <= 0) { clearInterval(timer); btn.disabled = false; btn.textContent = '获取验证码'; }
  }, 1000);
}

function registerUser() {
  var code = document.getElementById('verifyCode').value;
  var name = document.getElementById('userName').value;
  var age = parseInt(document.getElementById('userAge').value);
  var height = parseInt(document.getElementById('userHeight').value);
  var weight = parseInt(document.getElementById('userWeight').value);
  if (code !== '123456') { showToast('验证码错误'); return; }
  if (!name || !selectedGender || !age || !height || !weight) { showToast('请完善信息'); return; }
  currentUser = { type: 'user', name: name, gender: selectedGender, age: age, height: height, weight: weight };
  saveUserAndGoHome();
  showToast('🎉 欢迎，' + name);
}

function saveUserAndGoHome() {
  localStorage.setItem('ambroseUser', JSON.stringify(currentUser));
  localStorage.setItem('ambroseData', JSON.stringify(userData));
  showPage('homePage');
  updateHomePage();
  updateProfilePage();
}

// ==================== 积分系统 ====================
function addPoints(points) {
  userData.points += points;
  userData.totalPoints += points;
  checkLevelUp();
  saveData();
  updateHomePage();
}

function checkLevelUp() {
  var levels = [
    { name: '健身新手', min: 0 },
    { name: '健身达人', min: 1000 },
    { name: '运动高手', min: 3000 },
    { name: '健身专家', min: 6000 },
    { name: '健身大师', min: 10000 }
  ];
  for (var i = levels.length - 1; i >= 0; i--) {
    if (userData.totalPoints >= levels[i].min) {
      if (userData.level !== i + 1) {
        userData.level = i + 1;
        userData.levelName = levels[i].name;
        showToast('🎉 升级！' + levels[i].name);
      }
      break;
    }
  }
}

function getLevelProgress() {
  var levels = [0, 1000, 3000, 6000, 10000, 99999];
  var currentMin = levels[userData.level - 1];
  var nextMin = levels[userData.level];
  var progress = ((userData.totalPoints - currentMin) / (nextMin - currentMin)) * 100;
  return Math.min(Math.max(progress, 0), 100);
}

// ==================== 主页更新 ====================
function updateHomePage() {
  if (!currentUser) return;
  var now = new Date();
  var dateStr = now.toLocaleDateString('zh-CN', {month: 'long', day: 'numeric', weekday: 'long'});
  document.getElementById('homeDate').textContent = dateStr;
  var hour = now.getHours();
  var greet = hour < 12 ? '早上好' : (hour < 18 ? '下午好' : '晚上好');
  document.getElementById('homeGreeting').textContent = greet + '，' + currentUser.name;
  
  // 等级
  document.getElementById('levelBadge').textContent = 'LV.' + userData.level;
  document.getElementById('levelName').textContent = userData.levelName;
  document.getElementById('levelProgress').style.width = getLevelProgress() + '%';
  var levels = ['健身新手', '健身达人', '运动高手', '健身专家', '健身大师'];
  document.getElementById('nextLevel').textContent = levels[userData.level] || '满级';
  document.getElementById('pointsNeeded').textContent = Math.max(0, [1000, 3000, 6000, 10000, 99999][userData.level - 1] - userData.totalPoints);
  
  // 积分
  document.getElementById('totalPoints').textContent = userData.totalPoints;
  document.getElementById('badgeCount').textContent = userData.badges.length;
  document.getElementById('streakCount').textContent = userData.streak;
  
  // 目标
  var weight = currentUser.weight;
  document.getElementById('waterTarget').textContent = '/' + Math.round(weight * 35) + 'ml';
  document.getElementById('calTarget').textContent = '/' + Math.round(weight * 7) + '千卡';
  document.getElementById('waterCurrent').textContent = userData.todayData.water;
  document.getElementById('stepCurrent').textContent = userData.todayData.steps;
  document.getElementById('calCurrent').textContent = userData.todayData.calories;
  document.getElementById('sleepCurrent').textContent = userData.todayData.sleep;
  document.getElementById('waterProgress').style.width = Math.min(userData.todayData.water / (weight * 35) * 100, 100) + '%';
  document.getElementById('stepProgress').style.width = Math.min(userData.todayData.steps / 10000 * 100, 100) + '%';
  document.getElementById('calProgress').style.width = Math.min(userData.todayData.calories / (weight * 7) * 100, 100) + '%';
  document.getElementById('sleepProgress').style.width = Math.min(userData.todayData.sleep / 8 * 100, 100) + '%';
  
  // 任务
  renderTasks();
}

function renderTasks() {
  var list = document.getElementById('taskList');
  var html = '';
  userData.tasks.forEach(task => {
    var completed = task.completed ? 'completed' : '';
    var check = task.completed ? '✓' : '';
    var nameCls = task.completed ? 'completed' : '';
    html += `
      <div class="task-item ${completed}" onclick="completeTask(${task.id})">
        <div class="task-checkbox">${check}</div>
        <div class="task-info">
          <div class="task-name ${nameCls}">${task.name}</div>
          <div class="task-reward">${task.reward}</div>
        </div>
        <div class="task-icon">${task.icon}</div>
      </div>
    `;
  });
  list.innerHTML = html;
}

function completeTask(taskId) {
  // 首先检查是否需要重置每日数据
  checkAndResetDaily();
  
  var task = userData.tasks.find(t => t.id === taskId);
  if (!task) return;
  
  // 检查今天是否已完成过此任务
  if (task.completed) {
    showToast('⚠️ 今日已完成此任务，明天再来吧！');
    return;
  }
  
  task.completed = true;
  var points = parseInt(task.reward.replace(/\D/g, ''));
  addPoints(points);
  showToast('🎉 任务完成！' + task.reward);
  renderTasks();
  saveData();
}

// ==================== 快速记录 ====================
// ==================== 饮水功能（改进版） ====================
function showWaterSelector() {
  // 检查是否已存在
  var existing = document.getElementById('waterSelectorModal');
  if (existing) {
    existing.remove();
  }
  
  var html = '<div id="waterSelectorModal" style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.9); z-index: 100000; display: flex; align-items: center; justify-content: center; padding: 24px;">';
  html += '<div style="background: var(--bg-card); border: 1px solid var(--border); border-radius: 24px; padding: 32px 24px; width: 100%; max-width: 400px;">';
  html += '<div style="text-align: center; margin-bottom: 24px;">';
  html += '<div style="font-size: 48px; margin-bottom: 8px;">💧</div>';
  html += '<h3 style="font-size: 20px; margin-bottom: 4px;">记录饮水</h3>';
  html += '<p style="color: var(--text-secondary); font-size: 14px;">今日已饮水: ' + (userData.todayData.water || 0) + 'ml</p>';
  html += '</div>';
  
  // 快速选择按钮
  html += '<div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-bottom: 20px;">';
  [100, 200, 250, 300, 350, 500].forEach(amount => {
    html += `<button onclick="addWaterAmount(${amount})" style="padding: 16px; background: rgba(0,212,255,0.1); border: 1px solid rgba(0,212,255,0.3); border-radius: 12px; color: var(--primary); font-size: 16px; font-weight: 600; cursor: pointer;">
      <div>💧</div>
      <div>${amount}ml</div>
    </button>`;
  });
  html += '</div>';
  
  // 手动输入
  html += '<div style="margin-bottom: 20px;">';
  html += '<label style="display: block; color: var(--text-secondary); font-size: 14px; margin-bottom: 8px;">自定义水量 (ml)</label>';
  html += '<div style="display: flex; gap: 12px;">';
  html += '<input type="number" id="customWaterAmount" placeholder="输入水量" min="10" max="1000" step="10" style="flex: 1; padding: 16px; background: rgba(255,255,255,0.05); border: 1px solid var(--border); border-radius: 12px; color: #fff; font-size: 16px;">';
  html += '<button onclick="addCustomWater()" style="padding: 16px 24px; background: var(--primary); border: none; border-radius: 12px; color: #000; font-weight: 600; cursor: pointer;">添加</button>';
  html += '</div>';
  html += '</div>';
  
  // 滑块选择
  html += '<div style="margin-bottom: 24px;">';
  html += '<label style="display: block; color: var(--text-secondary); font-size: 14px; margin-bottom: 8px;">滑动选择: <span id="sliderValue">250</span>ml</label>';
  html += '<input type="range" min="10" max="500" value="250" step="10" oninput="document.getElementById(\'sliderValue\').textContent = this.value" onchange="addWaterAmount(this.value)" style="width: 100%; height: 8px; background: rgba(255,255,255,0.1); border-radius: 4px; outline: none; -webkit-appearance: none;">';
  html += '</div>';
  
  html += '<button onclick="closeWaterSelector()" style="width: 100%; padding: 16px; background: transparent; border: 1px solid var(--border); border-radius: 12px; color: var(--text-secondary); font-size: 16px; cursor: pointer;">取消</button>';
  html += '</div></div>';
  
  document.body.insertAdjacentHTML('beforeend', html);
}

function addWaterAmount(amount) {
  amount = parseInt(amount);
  userData.todayData.water = (userData.todayData.water || 0) + amount;
  addPoints(5);
  saveData();
  updateHomePage();
  closeWaterSelector();
  showToast('💧 +' + amount + 'ml +5积分');
}

function addCustomWater() {
  var input = document.getElementById('customWaterAmount');
  var amount = parseInt(input.value);
  if (amount && amount >= 10 && amount <= 1000) {
    addWaterAmount(amount);
  } else {
    showToast('请输入10-1000之间的数值');
  }
}

function closeWaterSelector() {
  var modal = document.getElementById('waterSelectorModal');
  if (modal) modal.remove();
}

// 旧版饮水函数保留兼容
function addWater() {
  showWaterSelector();
}

function addSteps() {
  userData.todayData.steps += 1000;
  addPoints(10);
  saveData();
  updateHomePage();
  showToast('👟 +1000步 +10积分');
}

function addSleep() {
  userData.todayData.sleep = 7.5;
  addPoints(15);
  saveData();
  updateHomePage();
  showToast('😴 已记录睡眠 +15积分');
}

// ==================== 训练功能 ====================
function filterWorkout(category, el) {
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  if (el) el.classList.add('active');
  
  var items = document.querySelectorAll('.workout-item');
  items.forEach(item => {
    if (category === 'all') {
      item.style.display = 'flex';
    } else {
      var itemCategory = item.getAttribute('data-category');
      item.style.display = itemCategory === category ? 'flex' : 'none';
    }
  });
}

function startWorkout(name, duration, calories) {
  currentWorkout = { name: name, duration: duration, calories: calories };
  document.getElementById('timerWorkoutName').textContent = name;
  workoutSeconds = 0;
  workoutRunning = false;
  updateTimerDisplay();
  var btn = document.getElementById('timerStartBtn');
  btn.innerHTML = '<span class="icon">▶️</span><span>开始</span>';
  btn.className = 'timer-btn primary';
  showPage('timerPage');
}

function updateTimerDisplay() {
  var m = Math.floor(workoutSeconds / 60);
  var s = workoutSeconds % 60;
  document.getElementById('timerDisplay').textContent = 
    (m < 10 ? '0' : '') + m + ':' + (s < 10 ? '0' : '') + s;
}

function toggleTimer() {
  var btn = document.getElementById('timerStartBtn');
  if (workoutRunning) {
    clearInterval(workoutTimer);
    workoutRunning = false;
    btn.innerHTML = '<span class="icon">▶️</span><span>继续</span>';
    btn.className = 'timer-btn primary';
  } else {
    workoutTimer = setInterval(() => { workoutSeconds++; updateTimerDisplay(); }, 1000);
    workoutRunning = true;
    btn.innerHTML = '<span class="icon">⏸️</span><span>暂停</span>';
    btn.className = 'timer-btn primary';
  }
}

function resetTimer() {
  clearInterval(workoutTimer);
  workoutRunning = false;
  workoutSeconds = 0;
  updateTimerDisplay();
  var btn = document.getElementById('timerStartBtn');
  btn.innerHTML = '<span class="icon">▶️</span><span>开始</span>';
  btn.className = 'timer-btn primary';
}

function finishWorkout() {
  // 检查今天是否已经打卡
  if (hasCheckedInToday()) {
    showToast('⚠️ 今日已打卡，明天继续加油！');
  }
  
  clearInterval(workoutTimer);
  workoutRunning = false;
  var minutes = Math.floor(workoutSeconds / 60) || 1;
  var calories = Math.round(minutes * (currentWorkout.calories / currentWorkout.duration));
  userData.todayData.calories += calories;
  userData.todayData.steps += Math.round(minutes * 100);
  
  // 记录打卡日期
  var now = new Date();
  var beijingTime = new Date(now.getTime() + (8 * 60 * 60 * 1000));
  var today = beijingTime.toISOString().split('T')[0];
  userData.lastCheckDate = today;
  
  // 添加到训练历史
  if (!userData.workoutHistory) {
    userData.workoutHistory = [];
  }
  userData.workoutHistory.push({
    date: beijingTime.toISOString(),
    name: currentWorkout.name,
    duration: minutes,
    calories: calories,
    feeling: '很棒'
  });
  
  // 完成任务
  var task = userData.tasks.find(t => t.id === 1);
  if (task && !task.completed) completeTask(1);
  
  // 徽章检查
  if (!userData.badges.includes('first_workout')) {
    userData.badges.push('first_workout');
    showToast('🏅 解锁徽章：初次训练！');
  }
  
  addPoints(50);
  saveData();
  updateHomePage();
  showToast('🎉 训练完成！+' + calories + '千卡 +50积分');
  showPage('workoutPage');
}

