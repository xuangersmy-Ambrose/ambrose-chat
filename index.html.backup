    html += '<div style="font-size: 11px; color: var(--text-secondary);">' + days[i] + '</div>';
    html += '</div>';
  });
  html += '</div></div>';
  
  // 运动分布
  html += '<div style="margin: 0 24px 24px; padding: 20px; background: var(--bg-card); border: 1px solid var(--border); border-radius: 16px;">';
  html += '<div style="font-weight: 600; margin-bottom: 16px;">🎯 运动类型分布</div>';
  html += '<div style="display: flex; flex-direction: column; gap: 12px;">';
  var types = [
    { name: '力量训练', percent: 40, color: '#00D4FF' },
    { name: '有氧燃脂', percent: 30, color: '#FF2D92' },
    { name: '瑜伽拉伸', percent: 20, color: '#30D158' },
    { name: '其他', percent: 10, color: '#FFD93D' }
  ];
  types.forEach(t => {
    html += `<div>
      <div style="display: flex; justify-content: space-between; margin-bottom: 6px; font-size: 14px;">
        <span>${t.name}</span><span>${t.percent}%</span>
      </div>
      <div style="height: 8px; background: rgba(255,255,255,0.1); border-radius: 4px; overflow: hidden;">
        <div style="width: ${t.percent}%; height: 100%; background: ${t.color}; border-radius: 4px;"></div>
      </div>
    </div>`;
  });
  html += '</div></div>';
  
  // 成就总结
  html += '<div style="margin: 0 24px 40px; padding: 20px; background: linear-gradient(135deg, rgba(255,215,0,0.1), rgba(255,140,0,0.1)); border: 1px solid rgba(255,215,0,0.3); border-radius: 16px;">';
  html += '<div style="font-weight: 600; margin-bottom: 12px; color: #FFD700;">🏆 本周成就</div>';
  html += '<div style="display: flex; flex-wrap: wrap; gap: 12px;">';
  html += '<span style="padding: 6px 12px; background: rgba(255,255,255,0.1); border-radius: 12px; font-size: 13px;">🔥 连续3天运动</span>';
  html += '<span style="padding: 6px 12px; background: rgba(255,255,255,0.1); border-radius: 12px; font-size: 13px;">💪 力量训练达人</span>';
  html += '<span style="padding: 6px 12px; background: rgba(255,255,255,0.1); border-radius: 12px; font-size: 13px;">⏱️ 单次最长45分钟</span>';
  html += '</div></div>';
  
  html += '<button class="btn-secondary" onclick="showPage(\'homePage\')" style="margin: 0 24px 40px;">← 返回首页</button>';
  html += '</div></div>';
  
  document.body.insertAdjacentHTML('beforeend', html);
  showPage('reportPage');
}

