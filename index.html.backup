// ==================== 体脂/围度记录完善 ====================
var bodyMeasurements = {
  weight: { current: 69.8, last: 70.5, target: 68 },
  bodyFat: { current: 18.5, last: 19.2, target: 15 },
  chest: { current: 95, last: 94, target: 96 },
  waist: { current: 82, last: 84, target: 78 },
  hip: { current: 96, last: 96, target: 95 },
  arm: { current: 32, last: 31, target: 33 },
  thigh: { current: 55, last: 56, target: 54 }
};

function showBodyMeasurements() {
  var html = '<div class="page" id="bodyMeasurementsPage"><div class="workout-page">';
  html += '<div class="page-header"><div class="page-title">📏 身体数据</div><div class="page-subtitle">记录每一次变化</div></div>';
  
  html += '<div style="padding: 0 24px;">';
  
  // 体重体脂卡片
  html += '<div style="background: var(--bg-card); border: 1px solid var(--border); border-radius: 20px; padding: 24px; margin-bottom: 20px;">';
  html += '<div style="font-weight: 600; margin-bottom: 20px;">⚖️ 基础数据</div>';
  html += '<div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px;">';
  
  var weightChange = bodyMeasurements.weight.last - bodyMeasurements.weight.current;
  var fatChange = bodyMeasurements.bodyFat.last - bodyMeasurements.bodyFat.current;
  
  html += '<div style="background: rgba(0,212,255,0.1); border-radius: 16px; padding: 20px; text-align: center;">';
  html += '<div style="font-size: 32px; font-weight: 800; color: var(--primary);">' + bodyMeasurements.weight.current + '</div>';
  html += '<div style="font-size: 12px; color: var(--text-secondary); margin-bottom: 4px;">体重(kg)</div>';
  html += '<div style="font-size: 12px; color: #30D158;">↓' + weightChange.toFixed(1) + 'kg</div>';
  html += '<div style="font-size: 11px; color: var(--text-secondary); margin-top: 4px;">目标: ' + bodyMeasurements.weight.target + 'kg</div>';
  html += '</div>';
  
  html += '<div style="background: rgba(255,45,146,0.1); border-radius: 16px; padding: 20px; text-align: center;">';
  html += '<div style="font-size: 32px; font-weight: 800; color: var(--secondary);">' + bodyMeasurements.bodyFat.current + '%</div>';
  html += '<div style="font-size: 12px; color: var(--text-secondary); margin-bottom: 4px;">体脂率</div>';
  html += '<div style="font-size: 12px; color: #30D158;">↓' + fatChange.toFixed(1) + '%</div>';
  html += '<div style="font-size: 11px; color: var(--text-secondary); margin-top: 4px;">目标: ' + bodyMeasurements.bodyFat.target + '%</div>';
  html += '</div>';
  
  html += '</div></div>';
  
  // 围度数据
  html += '<div style="background: var(--bg-card); border: 1px solid var(--border); border-radius: 20px; padding: 24px; margin-bottom: 20px;">';
  html += '<div style="font-weight: 600; margin-bottom: 20px;">📐 围度数据(cm)</div>';
  html += '<div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px;">';
  
  var parts = [
    { key: 'chest', name: '胸围' },
    { key: 'waist', name: '腰围' },
    { key: 'hip', name: '臀围' },
    { key: 'arm', name: '臂围' },
    { key: 'thigh', name: '腿围' }
  ];
  
  parts.forEach(part => {
    var data = bodyMeasurements[part.key];
    var change = data.current - data.last;
    var changeText = change > 0 ? '+' + change : change;
    var changeColor = part.key === 'waist' ? (change < 0 ? '#30D158' : '#FF6B6B') : (change > 0 ? '#30D158' : '#FF6B6B');
    
    html += '<div style="background: rgba(255,255,255,0.05); border-radius: 12px; padding: 16px; text-align: center;">';
    html += '<div style="font-size: 20px; font-weight: 700;">' + data.current + '</div>';
    html += '<div style="font-size: 11px; color: var(--text-secondary); margin-bottom: 4px;">' + part.name + '</div>';
    html += '<div style="font-size: 11px; color: ' + changeColor + ';">' + (change > 0 ? '↑' : '↓') + Math.abs(change) + '</div>';
    html += '</div>';
  });
  
  html += '</div></div>';
  
  // 记录按钮
  html += '<button class="btn-primary" onclick="showToast(\'✅ 今日数据已记录\')">记录今日数据</button>';
  html += '<button class="btn-secondary" onclick="showPage(\'profilePage\')" style="margin-top: 12px;">← 返回我的</button>';
  
  html += '</div></div></div>';
  
  document.body.insertAdjacentHTML('beforeend', html);
  showPage('bodyMeasurementsPage');
}

// ==================== 训练提醒推送设置 ====================
function showReminderSettings() {
  var html = '<div class="page" id="reminderSettingsPage"><div class="profile-page">';
  html += '<div class="page-header" style="padding-top: 60px;"><div class="page-title">🔔 提醒设置</div><div class="page-subtitle">定制你的训练提醒</div></div>';
  
  html += '<div style="padding: 0 24px;">';
  
  // 提醒开关
  html += '<div style="background: var(--bg-card); border: 1px solid var(--border); border-radius: 16px; padding: 20px; margin-bottom: 20px;">';
  html += '<div style="font-weight: 600; margin-bottom: 16px;">提醒开关</div>';
  
  var reminders = [
    { icon: '💪', name: '每日训练提醒', time: '19:00', enabled: true },
    { icon: '💧', name: '喝水提醒', time: '每小时', enabled: true },
    { icon: '😴', name: '睡眠提醒', time: '22:30', enabled: false },
    { icon: '🥗', name: '饮食记录提醒', time: '12:00', enabled: true }
  ];
  
  reminders.forEach((r, idx) => {
    var bg = r.enabled ? 'var(--primary)' : 'var(--border)';
    var pos = r.enabled ? 'right: 2px;' : 'left: 2px;';
    html += '<div style="display: flex; align-items: center; justify-content: space-between; padding: 16px 0; border-bottom: 1px solid rgba(255,255,255,0.05);">';
    html += '<div style="display: flex; align-items: center;"><div style="font-size: 24px; margin-right: 12px;">' + r.icon + '</div><div><div style="font-weight: 500;">' + r.name + '</div><div style="font-size: 12px; color: var(--text-secondary);">' + r.time + '</div></div></div>';
    html += '<div style="width: 48px; height: 28px; background: ' + bg + '; border-radius: 14px; position: relative; cursor: pointer;" onclick="toggleReminder(' + idx + ')"><div style="width: 24px; height: 24px; background: #fff; border-radius: 50%; position: absolute; top: 2px; ' + pos + ' transition: all 0.3s;"></div></div>';
    html += '</div>';
  });
  
  html += '</div>';
  
  // 提醒方式
  html += '<div style="background: var(--bg-card); border: 1px solid var(--border); border-radius: 16px; padding: 20px; margin-bottom: 40px;">';
  html += '<div style="font-weight: 600; margin-bottom: 16px;">提醒方式</div>';
  html += '<div style="display: flex; gap: 12px;">';
  html += '<div style="flex: 1; padding: 16px; background: rgba(0,212,255,0.1); border: 1px solid var(--primary); border-radius: 12px; text-align: center;"><div style="font-size: 24px; margin-bottom: 8px;">📱</div><div style="font-size: 13px;">推送通知</div></div>';
  html += '<div style="flex: 1; padding: 16px; background: rgba(255,255,255,0.05); border-radius: 12px; text-align: center;"><div style="font-size: 24px; margin-bottom: 8px;">📧</div><div style="font-size: 13px;">邮件提醒</div></div>';
  html += '</div></div>';
  
  html += '<button class="btn-secondary" onclick="showPage(\'settingsPage\')">← 返回设置</button>';
  html += '</div></div></div>';
  
  document.body.insertAdjacentHTML('beforeend', html);
  showPage('reminderSettingsPage');
}

function toggleReminder(idx) {
  showToast('✅ 提醒设置已更新');
}

// ==================== 数据存储 ====================
function saveData() {
  localStorage.setItem('ambroseData', JSON.stringify(userData));
}

function loadData() {
  var saved = localStorage.getItem('ambroseData');
  if (saved) {
    var parsed = JSON.parse(saved);
    Object.assign(userData, parsed);
  }
  // 检查并重置每日数据
  checkAndResetDaily();
}

// ==================== 每日重置检查 ====================
function checkAndResetDaily() {
  // 获取当前日期（使用北京时间）
  var now = new Date();
  var beijingTime = new Date(now.getTime() + (8 * 60 * 60 * 1000)); // 转换为北京时间
  var today = beijingTime.toISOString().split('T')[0];
  
  // 检查是否需要重置
  if (userData.lastCheckDate !== today) {
    // 新的一天，重置所有每日数据
    userData.lastCheckDate = today;
    userData.todayData = { water: 0, steps: 0, calories: 0, sleep: 0, meals: [] };
    
    // 重置任务状态
    if (userData.tasks) {
      userData.tasks.forEach(task => {
        task.completed = false;
      });
    }
    
    // 保存重置后的数据
    saveData();
    console.log('✅ 已重置每日数据:', today);
  }
}

// 获取今日是否已打卡
function hasCheckedInToday() {
  var now = new Date();
  var beijingTime = new Date(now.getTime() + (8 * 60 * 60 * 1000));
  var today = beijingTime.toISOString().split('T')[0];
  
  // 检查今日是否有训练记录
  if (userData.workoutHistory && userData.workoutHistory.length > 0) {
    var lastWorkout = userData.workoutHistory[userData.workoutHistory.length - 1];
    if (lastWorkout && lastWorkout.date) {
      var lastDate = lastWorkout.date.split('T')[0];
      return lastDate === today;
    }
  }
  return false;
}

// ==================== 进度条系统 ====================
function showProgressBar(title, percent) {
  var container = document.getElementById('globalProgress');
  if (!container) return;
  
  container.style.display = 'block';
  container.innerHTML = `
    <div style="
      position: fixed; top: 0; left: 0; right: 0; 
      background: rgba(10,10,10,0.98); 
      backdrop-filter: blur(20px);
      border-bottom: 1px solid rgba(255,255,255,0.1);
      padding: 16px 24px; z-index: 100000;
    ">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
        <span style="font-size: 14px; color: var(--text-secondary);">${title || '任务进度'}</span>
        <span style="font-size: 16px; font-weight: 700; color: var(--primary);">${percent}%</span>
      </div>
      <div style="height: 6px; background: rgba(255,255,255,0.1); border-radius: 3px; overflow: hidden;">
        <div style="
          height: 100%; width: ${percent}%; 
          background: ${percent === 100 ? '#30D158' : 'linear-gradient(90deg, #00D4FF, #FF2D92)'};
          border-radius: 3px; transition: all 0.5s ease;
        "></div>
      </div>
    </div>
  `;
}

function hideProgressBar() {
  var container = document.getElementById('globalProgress');
  if (container) {
    container.style.display = 'none';
  }
}

