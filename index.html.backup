var selectedPlanGoal = '';
var selectedPlanLevel = '';

function selectPlanGoal(goal) {
  selectedPlanGoal = goal;
  ['goalFatLoss', 'goalMuscle', 'goalYoga'].forEach(id => {
    var el = document.getElementById(id);
    if (el) el.classList.remove('selected');
  });
  document.getElementById('goal' + goal.charAt(0).toUpperCase() + goal.slice(1)).classList.add('selected');
}

function selectPlanLevel(level) {
  selectedPlanLevel = level;
  ['levelBeginner', 'levelIntermediate', 'levelAdvanced'].forEach(id => {
    var el = document.getElementById(id);
    if (el) el.classList.remove('selected');
  });
  document.getElementById('level' + level.charAt(0).toUpperCase() + level.slice(1)).classList.add('selected');
}

function generatePlan() {
  if (!selectedPlanGoal) { showToast('请选择健身目标'); return; }
  if (!selectedPlanLevel) { showToast('请选择运动基础'); return; }
  
  var planKey = selectedPlanLevel === 'beginner' ? 'beginner' : selectedPlanGoal;
  var plan = trainingPlans[planKey];
  
  var html = '<div class="page" id="planResultPage"><div class="workout-page">';
  html += '<div class="page-header"><div class="page-title">🎉 你的专属计划</div><div class="page-subtitle">' + plan.name + '</div></div>';
  
  html += '<div style="padding: 0 24px;">';
  html += '<div style="background: linear-gradient(135deg, rgba(0,212,255,0.1), rgba(255,45,146,0.1)); border: 1px solid rgba(0,212,255,0.3); border-radius: 20px; padding: 24px; margin-bottom: 20px;">';
  html += '<div style="text-align: center; margin-bottom: 20px;">';
  html += '<div style="font-size: 48px; margin-bottom: 12px;">🎯</div>';
  html += '<div style="font-size: 24px; font-weight: 700; margin-bottom: 8px;">' + plan.name + '</div>';
  html += '<div style="color: var(--text-secondary);">' + plan.description + '</div>';
  html += '</div>';
  
  html += '<div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; margin-bottom: 20px;">';
  html += '<div style="text-align: center; padding: 16px; background: rgba(255,255,255,0.05); border-radius: 12px;"><div style="font-size: 20px; font-weight: 700; color: var(--primary);">' + plan.duration + '</div><div style="font-size: 12px; color: var(--text-secondary);">计划周期</div></div>';
  html += '<div style="text-align: center; padding: 16px; background: rgba(255,255,255,0.05); border-radius: 12px;"><div style="font-size: 20px; font-weight: 700; color: var(--secondary);">' + plan.frequency + '</div><div style="font-size: 12px; color: var(--text-secondary);">训练频率</div></div>';
  html += '</div>';
  
  html += '<div style="font-weight: 600; margin-bottom: 12px;">📋 训练课程</div>';
  html += '<div style="display: flex; flex-direction: column; gap: 8px;">';
  plan.workouts.forEach((w, i) => {
    html += '<div style="display: flex; align-items: center; padding: 12px; background: rgba(255,255,255,0.05); border-radius: 12px;"><span style="margin-right: 12px;">' + ['一','二','三','四','五'][i] + '</span><span>' + w + '</span></div>';
  });
  html += '</div>';
  html += '</div>';
  
  html += '<button class="btn-primary" onclick="startPlan()">开始执行计划</button>';
  html += '<button class="btn-secondary" onclick="showPlanGenerator()" style="margin-top: 12px;">重新生成</button>';
  html += '</div>';
  
  html += '</div></div>';
  
  document.body.insertAdjacentHTML('beforeend', html);
  showPage('planResultPage');
  showToast('🎉 专属计划已生成！');
}

function startPlan() {
  showToast('🚀 计划已开始！加油！');
  showPage('homePage');
}

// ==================== 全局错误处理 ====================
window.onerror = function(msg, url, line) {
  console.error('❌ Error: ' + msg + '\nURL: ' + url + '\nLine: ' + line);
  return false;
};

// ==================== 内存清理 ====================
function cleanupPages() {
  var oldPages = document.querySelectorAll('.page:not(#welcomePage):not(#loginPage):not(#homePage):not(#workoutPage):not(#dietPage):not(#profilePage):not(#timerPage):not(#weightPage):not(#sleepPage):not(#historyPage):not(#settingsPage):not(#achievePage)');
  oldPages.forEach(function(page) {
    if (!page.classList.contains('active')) {
      page.remove();
    }
  });
}

// 每分钟清理一次
setInterval(cleanupPages, 60000);

// ==================== 数据验证 ====================
function validateInput(value, type) {
  if (value === null || value === undefined || value === '') {
    return { valid: false, msg: '输入不能为空' };
  }
  
  if (type === 'number') {
    var num = parseFloat(value);
    if (isNaN(num) || num <= 0) {
      return { valid: false, msg: '请输入有效的数字' };
    }
    if (num > 1000) {
      return { valid: false, msg: '数值过大，请检查' };
    }
  }
  
  if (type === 'phone') {
    if (!/^1[3-9]\d{9}$/.test(value)) {
      return { valid: false, msg: '手机号格式不正确' };
    }
  }
  
  return { valid: true, msg: '' };
}

// ==================== 安全的数据保存 ====================
function safeSaveData() {
  try {
    saveData();
    return true;
  } catch (e) {
    console.error('保存失败:', e);
    showToast('⚠️ 数据保存失败，请重试');
    return false;
  }
}

