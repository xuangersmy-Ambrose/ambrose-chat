<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="theme-color" content="#0a0a0a">
<link rel="manifest" href="/manifest.json">
<link rel="apple-touch-icon" href="/icon-192.png">
<title>AMBROSE - AI健康教练</title>
<script>
// 核心函数预定义（确保按钮点击可用）
window.showPage = function(pageId) {
  try {
    document.querySelectorAll('.page').forEach(function(p) { p.classList.remove('active'); });
    var target = document.getElementById(pageId);
    if (target) target.classList.add('active');
    window.scrollTo(0, 0);
  } catch(e) { console.error(e); }
};

window.switchMode = function(mode) {
  try {
    document.querySelectorAll('.mode-btn').forEach(function(b) { b.classList.remove('active'); });
    document.querySelectorAll('.login-form').forEach(function(f) { f.classList.remove('active'); });
    if (mode === 'boss') {
      document.getElementById('bossModeBtn').classList.add('active');
      document.getElementById('bossForm').classList.add('active');
    } else {
      document.getElementById('userModeBtn').classList.add('active');
      document.getElementById('userForm').classList.add('active');
    }
  } catch(e) { console.error(e); }
};

// 登录注册相关函数占位符（将在后面被覆盖）
window.loginBoss = window.loginBoss || function() { console.log('loginBoss not loaded yet'); };
window.sendVerifyCode = window.sendVerifyCode || function() { console.log('sendVerifyCode not loaded yet'); };
window.registerUser = window.registerUser || function() { console.log('registerUser not loaded yet'); };
window.selectGender = window.selectGender || function() { console.log('selectGender not loaded yet'); };
window.showToast = window.showToast || function(msg) { console.log('Toast:', msg); };
</script>
<style>
:root {
  --primary: #00D4FF;
  --primary-dark: #0099CC;
  --secondary: #FF2D92;
  --bg-dark: #0a0a0a;
  --bg-card: rgba(255,255,255,0.03);
  --border: rgba(255,255,255,0.1);
  --text-primary: #fff;
  --text-secondary: rgba(255,255,255,0.5);
}

* { margin: 0; padding: 0; box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
html, body { height: 100%; }
body { 
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif; 
  background: var(--bg-dark); 
  color: #fff; 
  overflow-x: hidden;
  -webkit-overflow-scrolling: touch;
}
::-webkit-scrollbar { width: 0; height: 0; }

.page { display: none; min-height: 100vh; padding-bottom: 100px; }
.page.active { display: block; animation: fadeIn 0.3s ease; }
@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

/* ========== 通用组件 ========== */
.btn-primary {
  width: 100%; padding: 18px;
  background: var(--primary); color: #000;
  border: none; border-radius: 16px;
  font-size: 17px; font-weight: 600;
  cursor: pointer; transition: all 0.3s;
}
.btn-primary:active { transform: scale(0.98); background: var(--primary-dark); }

.btn-secondary {
  width: 100%; padding: 18px;
  background: transparent; color: var(--primary);
  border: 1px solid var(--primary); border-radius: 16px;
  font-size: 17px; font-weight: 600; cursor: pointer;
}
.btn-secondary:active { background: rgba(0,212,255,0.1); }

.input-field {
  width: 100%; padding: 18px 20px;
  background: rgba(255,255,255,0.05);
  border: 1px solid var(--border); border-radius: 16px;
  color: #fff; font-size: 16px; transition: all 0.3s;
}
.input-field:focus { outline: none; border-color: var(--primary); background: rgba(0,212,255,0.05); }
.input-field::placeholder { color: var(--text-secondary); }

/* ========== 欢迎页 ========== */
.welcome-page {
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  min-height: 100vh; padding: 40px; text-align: center;
  background: var(--bg-dark);
}
.logo-container { position: relative; margin-bottom: 40px; }
.logo {
  width: 140px; height: 140px;
  background: linear-gradient(135deg, #00D4FF, #FF2D92);
  border-radius: 32px;
  display: flex; align-items: center; justify-content: center;
  font-size: 72px; font-weight: 800; color: #000;
  position: relative; z-index: 2;
}
.logo-glow {
  position: absolute; top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  width: 200px; height: 200px;
  background: linear-gradient(135deg, rgba(0,212,255,0.4), rgba(255,45,146,0.4));
  border-radius: 50%; filter: blur(40px); z-index: 1;
  animation: pulse 3s ease-in-out infinite;
  pointer-events: none; /* 防止遮挡点击 */
}
@keyframes pulse {
  0%, 100% { opacity: 0.6; transform: translate(-50%, -50%) scale(1); }
  50% { opacity: 1; transform: translate(-50%, -50%) scale(1.1); }
}
.brand-name { font-size: 48px; font-weight: 800; color: var(--primary); margin-bottom: 12px; letter-spacing: 2px; }
.brand-tagline { font-size: 16px; color: var(--text-secondary); margin-bottom: 80px; }

/* ========== 登录页 ========== */
.login-page { padding: 60px 24px; }
.login-header { text-align: center; margin-bottom: 40px; }
.login-title { font-size: 28px; font-weight: 700; margin-bottom: 8px; }
.login-subtitle { color: var(--text-secondary); font-size: 14px; }

.mode-selector { display: flex; gap: 12px; margin-bottom: 32px; }
.mode-btn { flex: 1; padding: 14px; background: rgba(255,255,255,0.05); border: 1px solid var(--border); border-radius: 12px; color: var(--text-secondary); font-size: 15px; cursor: pointer; transition: all 0.3s; }
.mode-btn.active { background: rgba(0,212,255,0.15); border-color: var(--primary); color: var(--primary); font-weight: 600; }

.login-form { display: none; }
.login-form.active { display: block; animation: fadeIn 0.3s ease; }

.form-group { margin-bottom: 20px; }
.form-label { display: block; color: var(--text-secondary); font-size: 14px; margin-bottom: 8px; }

.phone-input-group { display: flex; gap: 12px; }
.phone-input-group .input-field { flex: 1; }
.code-btn { padding: 18px 20px; background: rgba(0,212,255,0.1); border: 1px solid rgba(0,212,255,0.3); border-radius: 16px; color: var(--primary); font-size: 14px; font-weight: 500; cursor: pointer; white-space: nowrap; }
.code-btn:disabled { opacity: 0.4; cursor: not-allowed; }

.gender-selector { display: flex; gap: 16px; }
.gender-option { flex: 1; padding: 24px; background: rgba(255,255,255,0.03); border: 1px solid var(--border); border-radius: 16px; text-align: center; cursor: pointer; transition: all 0.3s; }
.gender-option.selected { border-color: var(--primary); background: rgba(0,212,255,0.1); }
.gender-option .icon { font-size: 32px; margin-bottom: 8px; }
.gender-option .text { font-size: 14px; color: var(--text-secondary); }
.gender-option.selected .text { color: var(--primary); font-weight: 600; }

.hint-text { color: var(--text-secondary); font-size: 12px; margin-top: 8px; }

/* ========== 主页 ========== */
.home-page { background: var(--bg-dark); padding-bottom: 100px; }
.home-header { padding: 60px 24px 24px; }
.home-date { color: var(--primary); font-size: 13px; font-weight: 500; margin-bottom: 4px; }
.home-greeting { font-size: 28px; font-weight: 700; margin-bottom: 4px; }
.home-subtitle { color: var(--text-secondary); font-size: 14px; }

/* 等级卡片 */
.level-card {
  display: flex; align-items: center; gap: 16px;
  margin: 0 24px 20px; padding: 20px;
  background: linear-gradient(135deg, rgba(0,212,255,0.15), rgba(255,45,146,0.1));
  border: 1px solid rgba(0,212,255,0.3); border-radius: 20px;
}
.level-avatar { width: 56px; height: 56px; background: linear-gradient(135deg, var(--primary), var(--secondary)); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 28px; }
.level-info { flex: 1; }
.level-row { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; }
.level-badge { padding: 4px 10px; background: rgba(255,215,0,0.2); border: 1px solid rgba(255,215,0,0.4); border-radius: 12px; font-size: 12px; color: #FFD700; font-weight: 600; }
.level-name { font-size: 18px; font-weight: 700; }
.level-progress-bg { height: 6px; background: rgba(255,255,255,0.1); border-radius: 3px; overflow: hidden; }
.level-progress-bar { height: 100%; background: linear-gradient(90deg, var(--primary), var(--secondary)); border-radius: 3px; transition: width 0.5s ease; }
.level-text { font-size: 12px; color: var(--text-secondary); margin-top: 4px; }

/* 连续打卡 */
.streak-card {
  display: flex; align-items: center; gap: 12px;
  margin: 0 24px 24px; padding: 16px 20px;
  background: linear-gradient(135deg, rgba(255,45,146,0.15), rgba(255,107,107,0.1));
  border: 1px solid rgba(255,45,146,0.3); border-radius: 16px;
}
.streak-icon { font-size: 28px; animation: flame 1s ease-in-out infinite; }
@keyframes flame { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.1); } }
.streak-info { flex: 1; }
.streak-count { font-size: 20px; font-weight: 700; color: #FF6B6B; }
.streak-label { font-size: 12px; color: var(--text-secondary); }
.streak-days { display: flex; gap: 6px; }
.day-dot { width: 8px; height: 8px; background: rgba(255,255,255,0.2); border-radius: 50%; }
.day-dot.active { background: #FF6B6B; box-shadow: 0 0 8px #FF6B6B; }

/* 积分展示 */
.points-display {
  display: flex; justify-content: space-around;
  margin: 0 24px 24px; padding: 20px;
  background: var(--bg-card); border: 1px solid var(--border); border-radius: 16px;
}
.point-item { text-align: center; }
.point-value { font-size: 24px; font-weight: 700; color: var(--primary); }
.point-label { font-size: 12px; color: var(--text-secondary); margin-top: 4px; }

/* 目标卡片 */
.goals-section { padding: 0 24px; margin-bottom: 32px; }
.section-title { font-size: 18px; font-weight: 600; margin-bottom: 16px; display: flex; align-items: center; gap: 8px; }
.section-title .more { margin-left: auto; font-size: 13px; color: var(--text-secondary); font-weight: 400; }

.goals-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; }
.goal-card {
  background: var(--bg-card); border: 1px solid var(--border); border-radius: 20px;
  padding: 20px; position: relative; cursor: pointer; transition: all 0.3s;
}
.goal-card:active { transform: scale(0.98); border-color: var(--primary); }
.goal-card::before {
  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
  background: linear-gradient(90deg, var(--primary), var(--secondary)); border-radius: 20px 20px 0 0;
}
.goal-icon { font-size: 24px; margin-bottom: 12px; }
.goal-value { font-size: 24px; font-weight: 700; margin-bottom: 4px; }
.goal-value .target { font-size: 13px; color: var(--text-secondary); font-weight: 400; }
.goal-label { font-size: 12px; color: var(--text-secondary); margin-bottom: 12px; }
.goal-progress { height: 4px; background: rgba(255,255,255,0.1); border-radius: 2px; overflow: hidden; }
.goal-progress-bar { height: 100%; background: linear-gradient(90deg, var(--primary), var(--secondary)); border-radius: 2px; transition: width 0.5s ease; }
.goal-add-btn { position: absolute; top: 16px; right: 16px; width: 28px; height: 28px; background: rgba(0,212,255,0.2); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 18px; color: var(--primary); }

/* 快捷功能 */
.quick-actions { padding: 0 24px; margin-bottom: 32px; }
.actions-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; }
.action-item { display: flex; flex-direction: column; align-items: center; padding: 16px 8px; background: var(--bg-card); border: 1px solid var(--border); border-radius: 16px; cursor: pointer; transition: all 0.3s; }
.action-item:active { transform: scale(0.95); border-color: var(--primary); }
.action-icon { width: 48px; height: 48px; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 24px; margin-bottom: 8px; }
.action-icon.workout { background: linear-gradient(135deg, #FF2D92, #FF6B6B); }
.action-icon.diet { background: linear-gradient(135deg, #30D158, var(--primary)); }
.action-icon.weight { background: linear-gradient(135deg, #FFD93D, #FF8C42); }
.action-icon.sleep { background: linear-gradient(135deg, #9B59B6, #3498DB); }
.action-icon.achieve { background: linear-gradient(135deg, #FFD700, #FF8C00); }
.action-text { font-size: 12px; color: var(--text-secondary); }

/* 今日任务 */
.tasks-section { padding: 0 24px; }
.task-list { display: flex; flex-direction: column; gap: 12px; }
.task-item { display: flex; align-items: center; padding: 16px; background: var(--bg-card); border: 1px solid var(--border); border-radius: 16px; cursor: pointer; transition: all 0.3s; }
.task-item:active { border-color: var(--primary); }
.task-item.completed { opacity: 0.6; }
.task-checkbox { width: 24px; height: 24px; border: 2px solid var(--border); border-radius: 50%; margin-right: 16px; display: flex; align-items: center; justify-content: center; font-size: 14px; transition: all 0.3s; }
.task-item.completed .task-checkbox { background: var(--primary); border-color: var(--primary); color: #000; }
.task-info { flex: 1; }
.task-name { font-size: 15px; font-weight: 500; margin-bottom: 4px; }
.task-name.completed { text-decoration: line-through; color: var(--text-secondary); }
.task-reward { font-size: 12px; color: var(--primary); }
.task-icon { font-size: 24px; }

/* ========== 训练页 ========== */
.workout-page { background: var(--bg-dark); }
.page-header { padding: 60px 24px 20px; }
.page-title { font-size: 28px; font-weight: 700; margin-bottom: 4px; }
.page-subtitle { color: var(--text-secondary); font-size: 14px; }

.category-tabs { display: flex; gap: 12px; padding: 0 24px 20px; overflow-x: auto; }
.tab { padding: 10px 20px; background: rgba(255,255,255,0.05); border: 1px solid var(--border); border-radius: 20px; font-size: 14px; white-space: nowrap; cursor: pointer; transition: all 0.3s; }
.tab.active { background: var(--primary); color: #000; border-color: var(--primary); font-weight: 600; }

.workout-list { padding: 0 24px; }
.workout-item { display: flex; align-items: center; padding: 16px; background: var(--bg-card); border: 1px solid var(--border); border-radius: 20px; margin-bottom: 12px; cursor: pointer; transition: all 0.3s; }
.workout-item:active { border-color: var(--primary); }
.workout-thumb { width: 80px; height: 80px; background: linear-gradient(135deg, var(--primary), var(--secondary)); border-radius: 16px; display: flex; align-items: center; justify-content: center; font-size: 36px; margin-right: 16px; }
.workout-info { flex: 1; }
.workout-name { font-size: 16px; font-weight: 600; margin-bottom: 6px; }
.workout-meta { font-size: 13px; color: var(--text-secondary); }
.workout-meta span { margin-right: 12px; }
.workout-play-btn { width: 44px; height: 44px; background: rgba(0,212,255,0.2); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 20px; }

/* ========== 计时器页 ========== */
.timer-page { background: var(--bg-dark); display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 100vh; padding: 40px 24px; }
.timer-workout-name { font-size: 24px; font-weight: 600; margin-bottom: 8px; text-align: center; }
.timer-hint { color: var(--text-secondary); font-size: 14px; margin-bottom: 60px; }
.timer-display { font-size: 80px; font-weight: 200; font-family: 'Courier New', monospace; margin-bottom: 60px; text-shadow: 0 0 30px rgba(0,212,255,0.3); }
.timer-controls { display: flex; gap: 24px; margin-bottom: 40px; }
.timer-btn { width: 80px; height: 80px; border-radius: 50%; border: none; font-size: 14px; font-weight: 600; cursor: pointer; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 4px; transition: all 0.3s; }
.timer-btn .icon { font-size: 24px; }
.timer-btn.primary { background: var(--primary); color: #000; width: 100px; height: 100px; font-size: 16px; }
.timer-btn.secondary { background: rgba(255,255,255,0.1); color: #fff; }
.timer-btn:active { transform: scale(0.95); }

/* ========== 饮食页 ========== */
.diet-page { background: var(--bg-dark); }
.calorie-card {
  margin: 0 24px 24px; padding: 28px;
  background: linear-gradient(135deg, rgba(0,212,255,0.1), rgba(255,45,146,0.1));
  border: 1px solid rgba(0,212,255,0.2); border-radius: 24px;
}
.calorie-main { text-align: center; margin-bottom: 24px; }
.calorie-value { font-size: 56px; font-weight: 800; background: linear-gradient(135deg, var(--primary), var(--secondary)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
.calorie-label { color: var(--text-secondary); font-size: 14px; margin-top: 4px; }
.calorie-stats { display: flex; justify-content: space-around; padding-top: 24px; border-top: 1px solid rgba(255,255,255,0.1); }
.cal-stat { text-align: center; }
.cal-stat-value { font-size: 20px; font-weight: 700; color: var(--primary); margin-bottom: 4px; }
.cal-stat-label { font-size: 12px; color: var(--text-secondary); }

.meal-list { padding: 0 24px; }
.meal-item { display: flex; align-items: center; padding: 16px; background: var(--bg-card); border: 1px solid var(--border); border-radius: 16px; margin-bottom: 12px; }
.meal-icon { width: 48px; height: 48px; background: rgba(255,255,255,0.1); border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 24px; margin-right: 16px; }
.meal-info { flex: 1; }
.meal-name { font-size: 16px; font-weight: 500; margin-bottom: 4px; }
.meal-hint { font-size: 13px; color: var(--text-secondary); }
.meal-add { width: 36px; height: 36px; background: var(--primary); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 24px; color: #000; cursor: pointer; }

/* ========== 成就页 ========== */
.achieve-page { background: var(--bg-dark); }
.achieve-header { padding: 60px 24px 24px; text-align: center; }
.achieve-stats { display: flex; justify-content: center; gap: 40px; margin-bottom: 32px; }
.achieve-stat { text-align: center; }
.achieve-stat-value { font-size: 36px; font-weight: 800; background: linear-gradient(135deg, #FFD700, #FF8C00); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
.achieve-stat-label { font-size: 13px; color: var(--text-secondary); margin-top: 4px; }

.badge-grid { padding: 0 24px; display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
.badge-item { text-align: center; padding: 20px 12px; background: var(--bg-card); border: 1px solid var(--border); border-radius: 16px; transition: all 0.3s; }
.badge-item.unlocked { border-color: rgba(255,215,0,0.5); background: rgba(255,215,0,0.05); }
.badge-item.locked { opacity: 0.5; }
.badge-icon { font-size: 40px; margin-bottom: 12px; }
.badge-name { font-size: 13px; font-weight: 500; margin-bottom: 4px; }
.badge-item.locked .badge-name { color: var(--text-secondary); }
.badge-desc { font-size: 11px; color: var(--text-secondary); }

/* ========== 我的页 ========== */
.profile-page { background: var(--bg-dark); }
.profile-header { text-align: center; padding: 60px 24px 32px; }
.profile-avatar { width: 100px; height: 100px; background: linear-gradient(135deg, var(--primary), var(--secondary)); border-radius: 50%; margin: 0 auto 16px; display: flex; align-items: center; justify-content: center; font-size: 48px; box-shadow: 0 10px 40px rgba(0,212,255,0.3); }
.profile-name { font-size: 24px; font-weight: 700; margin-bottom: 4px; }
.profile-info { color: var(--text-secondary); font-size: 14px; }

.profile-stats { display: flex; justify-content: space-around; margin: 0 24px 32px; padding: 20px; background: var(--bg-card); border: 1px solid var(--border); border-radius: 20px; }
.profile-stat { text-align: center; }
.profile-stat-value { font-size: 28px; font-weight: 700; background: linear-gradient(135deg, var(--primary), var(--secondary)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; margin-bottom: 4px; }
.profile-stat-label { font-size: 12px; color: var(--text-secondary); }

.menu-list { padding: 0 24px; }
.menu-item { display: flex; align-items: center; padding: 18px 16px; background: var(--bg-card); border: 1px solid var(--border); border-radius: 16px; margin-bottom: 12px; cursor: pointer; transition: all 0.3s; }
.menu-item:active { border-color: var(--primary); }
.menu-icon { width: 40px; height: 40px; background: rgba(255,255,255,0.1); border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 20px; margin-right: 16px; }
.menu-text { flex: 1; font-size: 15px; }
.menu-arrow { color: var(--text-secondary); font-size: 20px; }

.logout-btn { margin-top: 20px; }
.logout-btn .menu-icon { background: rgba(255,107,107,0.1); }
.logout-btn .menu-text { color: #FF6B6B; }

/* ========== AI对话页 ========== */
.chat-page { background: var(--bg-dark); min-height: 100vh; padding-bottom: 200px; }

/* 情感状态栏 */
.emotion-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12px;
  padding: 12px 24px;
  margin: 0 24px 20px;
  background: linear-gradient(135deg, rgba(0,212,255,0.1), rgba(255,45,146,0.1));
  border: 1px solid rgba(0,212,255,0.3);
  border-radius: 50px;
  animation: pulse 2s infinite;
}
@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.7; }
}
.emotion-indicator {
  font-size: 24px;
  animation: bounce 1s infinite;
}
@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-3px); }
}
.emotion-text {
  font-size: 14px;
  color: var(--text-secondary);
}

/* 对话容器 */
.chat-container {
  padding: 0 24px;
  display: flex;
  flex-direction: column;
  gap: 16px;
}

/* 消息样式 */
.chat-message {
  display: flex;
  gap: 12px;
  max-width: 85%;
  animation: messageSlide 0.3s ease;
}
@keyframes messageSlide {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}

.chat-message.bot-message { align-self: flex-start; }
.chat-message.user-message { align-self: flex-end; flex-direction: row-reverse; }

.message-avatar {
  width: 40px;
  height: 40px;
  background: linear-gradient(135deg, var(--primary), var(--secondary));
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  flex-shrink: 0;
}
.chat-message.user-message .message-avatar {
  background: rgba(255,255,255,0.1);
}

.message-content {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 20px;
  padding: 12px 16px;
  max-width: calc(100% - 52px);
}
.chat-message.user-message .message-content {
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  border-color: transparent;
}

.message-text {
  font-size: 15px;
  line-height: 1.5;
  word-wrap: break-word;
}
.message-time {
  font-size: 11px;
  color: var(--text-secondary);
  margin-top: 6px;
  text-align: right;
}
.chat-message.user-message .message-time {
  color: rgba(0,0,0,0.5);
}

/* 快捷建议 */
.chat-suggestions {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  padding: 16px 24px;
  margin-top: 10px;
}
.suggestion-chip {
  padding: 10px 16px;
  background: rgba(0,212,255,0.1);
  border: 1px solid rgba(0,212,255,0.3);
  border-radius: 20px;
  font-size: 13px;
  color: var(--primary);
  cursor: pointer;
  transition: all 0.3s;
}
.suggestion-chip:active {
  background: var(--primary);
  color: #000;
  transform: scale(0.95);
}

/* 输入区域 */
.chat-input-area {
  position: fixed;
  bottom: 80px;
  left: 0;
  right: 0;
  padding: 16px 24px;
  background: linear-gradient(to top, var(--bg-dark), transparent);
}
.input-wrapper {
  display: flex;
  gap: 12px;
  align-items: center;
}
.chat-input {
  flex: 1;
  padding: 16px 20px;
  background: rgba(255,255,255,0.05);
  border: 1px solid var(--border);
  border-radius: 50px;
  font-size: 15px;
  color: #fff;
  outline: none;
}
.chat-input:focus {
  border-color: var(--primary);
  background: rgba(0,212,255,0.05);
}
.send-btn {
  width: 50px;
  height: 50px;
  background: var(--primary);
  border: none;
  border-radius: 50%;
  font-size: 20px;
  color: #000;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
}
.send-btn:active {
  transform: scale(0.95);
  background: var(--primary-dark);
}
.input-hint {
  text-align: center;
  font-size: 12px;
  color: var(--text-secondary);
  margin-top: 10px;
}

/* 打字指示器 */
.typing-indicator {
  display: flex;
  gap: 4px;
  padding: 8px 12px;
}
.typing-indicator span {
  width: 8px;
  height: 8px;
  background: var(--primary);
  border-radius: 50%;
  animation: typing 1.4s infinite;
}
.typing-indicator span:nth-child(2) { animation-delay: 0.2s; }
.typing-indicator span:nth-child(3) { animation-delay: 0.4s; }
@keyframes typing {
  0%, 60%, 100% { transform: translateY(0); }
  30% { transform: translateY(-10px); }
}

/* ========== 底部导航 ========== */
.bottom-nav {
  position: fixed; bottom: 0; left: 0; right: 0;
  display: flex; justify-content: space-around;
  padding: 12px 0 30px;
  background: rgba(10,10,10,0.98); backdrop-filter: blur(20px);
  border-top: 1px solid rgba(255,255,255,0.05); z-index: 1000;
}
.nav-item { flex: 1; display: flex; flex-direction: column; align-items: center; padding: 8px; cursor: pointer; opacity: 0.4; transition: all 0.3s; position: relative; }
.nav-item.active { opacity: 1; }
.nav-item.active::before { content: ''; position: absolute; top: 0; width: 20px; height: 3px; background: var(--primary); border-radius: 0 0 2px 2px; }
.nav-item .icon { font-size: 24px; margin-bottom: 4px; }
.nav-item .text { font-size: 11px; }

/* ========== Toast ========== */
.toast {
  position: fixed; top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(40,40,40,0.98); padding: 16px 28px;
  border-radius: 12px; color: #fff; font-size: 15px;
  z-index: 100000; display: none;
  border: 1px solid rgba(255,255,255,0.1);
}
.toast.show { display: block; animation: toastIn 0.3s ease; }
@keyframes toastIn { from { opacity: 0; transform: translate(-50%, -40%); } to { opacity: 1; transform: translate(-50%, -50%); } }

/* ========== 签到弹窗 ========== */
.modal-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.8); z-index: 100001; display: none; align-items: center; justify-content: center; padding: 24px; }
.modal-overlay.show { display: flex; }
.modal-content { background: var(--bg-dark); border: 1px solid var(--border); border-radius: 24px; padding: 32px 24px; text-align: center; width: 100%; max-width: 340px; }
.modal-title { font-size: 24px; font-weight: 700; margin-bottom: 8px; }
.modal-subtitle { color: var(--text-secondary); font-size: 14px; margin-bottom: 24px; }
.signin-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 8px; margin-bottom: 24px; }
.signin-day { padding: 12px 4px; background: rgba(255,255,255,0.03); border: 1px solid var(--border); border-radius: 12px; }
.signin-day.active { background: rgba(0,212,255,0.15); border-color: var(--primary); }
.signin-day.completed { background: rgba(255,215,0,0.15); border-color: rgba(255,215,0,0.5); }
.signin-day .day-label { font-size: 11px; color: var(--text-secondary); margin-bottom: 4px; }
.signin-day .day-icon { font-size: 20px; }
.signin-day .day-points { font-size: 11px; color: var(--primary); margin-top: 4px; }
.signin-reward { padding: 16px; background: linear-gradient(135deg, rgba(255,215,0,0.1), rgba(255,140,0,0.1)); border: 1px solid rgba(255,215,0,0.3); border-radius: 16px; margin-bottom: 24px; }
.signin-reward-icon { font-size: 40px; margin-bottom: 8px; }
.signin-reward-text { font-size: 16px; font-weight: 600; color: #FFD700; }
</style>
</head>
<body>

<!-- 动态进度条容器 -->
<div id="globalProgress" style="display:none;"></div>

<!-- Toast -->
<div class="toast" id="toast"></div>

<!-- 签到弹窗 -->
<div class="modal-overlay" id="signinModal">
<div class="modal-content">
<div class="modal-title">🔥 每日签到</div>
<div class="modal-subtitle">连续签到获得更多奖励</div>
<div class="signin-grid" id="signinGrid">
<!-- JS生成 -->
</div>
<div class="signin-reward" id="todayReward">
<div class="signin-reward-icon">🎁</div>
<div class="signin-reward-text">今日奖励: +50 积分</div>
</div>
<button class="btn-primary" onclick="doSignin()">立即签到</button>
<button class="btn-secondary" onclick="closeSignin()" style="margin-top: 12px;">稍后再说</button>
</div>
</div>

<!-- ========== 欢迎页 ========== -->
<div class="page active" id="welcomePage">
<div class="welcome-page">
<div class="logo-container">
<div class="logo-glow"></div>
<div class="logo">A</div>
</div>
<div class="brand-name">AMBROSE</div>
<div class="brand-tagline">AI智能健康教练</div>
<button class="btn-primary" onclick="console.log('Button clicked!'); showPage('loginPage');" style="margin-top: 60px; position: relative; z-index: 10;">开始使用</button>
</div>
</div>

<!-- ========== 登录页 ========== -->
<div class="page" id="loginPage">
<div class="login-page">
<div class="login-header">
<div class="login-title">欢迎回来</div>
<div class="login-subtitle">选择你的身份开始</div>
</div>

<div class="mode-selector">
<button class="mode-btn active" onclick="switchMode('boss')" id="bossModeBtn">👑 BOSS</button>
<button class="mode-btn" onclick="switchMode('user')" id="userModeBtn">👤 用户</button>
</div>

<!-- BOSS登录 -->
<div class="login-form active" id="bossForm">
<div class="form-group">
<label class="form-label">专属识别码</label>
<input type="password" class="input-field" id="bossCode" placeholder="请输入4位识别码" maxlength="4">
<p class="hint-text">💡 提示：BOSS识别码为 0812</p>
</div>
<button class="btn-primary" onclick="loginBoss()" style="margin-top: 40px;">进入系统</button>
</div>

<!-- 用户注册 -->
<div class="login-form" id="userForm">
<div class="form-group">
<label class="form-label">手机号码</label>
<div class="phone-input-group">
<input type="tel" class="input-field" id="phoneInput" placeholder="11位手机号" maxlength="11">
<button class="code-btn" id="sendCodeBtn" onclick="sendVerifyCode()">获取验证码</button>
</div>
</div>

<div class="form-group">
<label class="form-label">验证码</label>
<input type="text" class="input-field" id="verifyCode" placeholder="6位验证码" maxlength="6">
<p class="hint-text">💡 测试验证码：123456</p>
</div>

<div class="form-group">
<label class="form-label">性别</label>
<div class="gender-selector">
<div class="gender-option" onclick="selectGender('male')" id="genderMale">
<div class="icon">👨</div>
<div class="text">男士</div>
</div>
<div class="gender-option" onclick="selectGender('female')" id="genderFemale">
<div class="icon">👩</div>
<div class="text">女士</div>
</div>
</div>
</div>

<div class="form-group">
<label class="form-label">身体数据</label>
<input type="text" class="input-field" id="userName" placeholder="姓名">
<input type="number" class="input-field" id="userAge" placeholder="年龄 (岁)" style="margin-top: 12px;">
<input type="number" class="input-field" id="userHeight" placeholder="身高 (cm)" style="margin-top: 12px;">
<input type="number" class="input-field" id="userWeight" placeholder="体重 (kg)" style="margin-top: 12px;">
</div>

<button class="btn-primary" onclick="registerUser()" style="margin-top: 40px;">创建账户</button>
</div>
</div>
</div>

<!-- ========== 主页 ========== -->
<div class="page" id="homePage">
<div class="home-page">
<div class="home-header">
<div class="home-date" id="homeDate">--月--日 星期-</div>
<div class="home-greeting" id="homeGreeting">你好</div>
<div class="home-subtitle">今天也要加油哦 💪</div>
</div>

<!-- 等级卡片 -->
<div class="level-card">
<div class="level-avatar" id="levelAvatar">🥉</div>
<div class="level-info">
<div class="level-row">
<span class="level-badge" id="levelBadge">LV.1</span>
<span class="level-name" id="levelName">健身新手</span>
</div>
<div class="level-progress-bg">
<div class="level-progress-bar" id="levelProgress" style="width: 35%"></div>
</div>
<div class="level-text">再获得 <span id="pointsNeeded">650</span> 积分升级到 <span id="nextLevel">健身达人</span></div>
</div>
</div>

<!-- 连续打卡 -->
<div class="streak-card" onclick="showSigninModal()">
<div class="streak-icon">🔥</div>
<div class="streak-info">
<div class="streak-count">连续打卡 <span id="streakCount">3</span> 天</div>
<div class="streak-label">点击查看签到详情</div>
</div>
<div class="streak-days" id="streakDays">
<div class="day-dot active"></div>
<div class="day-dot active"></div>
<div class="day-dot active"></div>
<div class="day-dot"></div>
<div class="day-dot"></div>
<div class="day-dot"></div>
<div class="day-dot"></div>
</div>
</div>

<!-- 积分展示 -->
<div class="points-display">
<div class="point-item">
<div class="point-value" id="totalPoints">350</div>
<div class="point-label">总积分</div>
</div>
<div class="point-item">
<div class="point-value" id="todayPoints">+50</div>
<div class="point-label">今日获得</div>
</div>
<div class="point-item">
<div class="point-value" id="badgeCount">5</div>
<div class="point-label">徽章</div>
</div>
</div>

<!-- 今日目标 -->
<div class="goals-section">
<div class="section-title">🎯 今日目标</div>
<div class="goals-grid">
<div class="goal-card" onclick="addWater()">
<div class="goal-add-btn">+</div>
<div class="goal-icon">💧</div>
<div class="goal-value"><span id="waterCurrent">0</span><span class="target" id="waterTarget">/2000ml</span></div>
<div class="goal-label">饮水</div>
<div class="goal-progress"><div class="goal-progress-bar" id="waterProgress" style="width: 0%"></div></div>
</div>
<div class="goal-card" onclick="addSteps()">
<div class="goal-add-btn">+</div>
<div class="goal-icon">👟</div>
<div class="goal-value"><span id="stepCurrent">0</span><span class="target" id="stepTarget">/10000</span></div>
<div class="goal-label">步数</div>
<div class="goal-progress"><div class="goal-progress-bar" id="stepProgress" style="width: 0%"></div></div>
</div>
<div class="goal-card">
<div class="goal-icon">🔥</div>
<div class="goal-value"><span id="calCurrent">0</span><span class="target" id="calTarget">/500千卡</span></div>
<div class="goal-label">消耗</div>
<div class="goal-progress"><div class="goal-progress-bar" id="calProgress" style="width: 0%"></div></div>
</div>
<div class="goal-card" onclick="addSleep()">
<div class="goal-add-btn">+</div>
<div class="goal-icon">😴</div>
<div class="goal-value"><span id="sleepCurrent">0</span><span class="target" id="sleepTarget">/8小时</span></div>
<div class="goal-label">睡眠</div>
<div class="goal-progress"><div class="goal-progress-bar" id="sleepProgress" style="width: 0%"></div></div>
</div>
</div>
</div>

<!-- 快捷功能 -->
<div class="quick-actions">
<div class="section-title">⚡ 快捷功能</div>
<div class="actions-grid">
<div class="action-item" onclick="showPage('workoutPage')">
<div class="action-icon workout">💪</div>
<div class="action-text">开始训练</div>
</div>
<div class="action-item" onclick="showPage('dietPage')">
<div class="action-icon diet">🥗</div>
<div class="action-text">记录饮食</div>
</div>
<div class="action-item" onclick="showPage('achievePage')">
<div class="action-icon achieve">🏆</div>
<div class="action-text">成就徽章</div>
</div>
<div class="action-item" onclick="showLeaderboard()">
<div class="action-icon" style="background: linear-gradient(135deg, #FFD700, #FF8C00);">📊</div>
<div class="action-text">排行榜</div>
</div>
<div class="action-item" onclick="showCommunity()">
<div class="action-icon" style="background: linear-gradient(135deg, #9B59B6, #3498DB);">👥</div>
<div class="action-text">社区</div>
</div>
<div class="action-item" onclick="showReport()">
<div class="action-icon" style="background: linear-gradient(135deg, #30D158, #00D4FF);">📈</div>
<div class="action-text">数据报告</div>
</div>
<div class="action-item" onclick="showCoursePage()">
<div class="action-icon" style="background: linear-gradient(135deg, #FF2D92, #FF6B6B);">📚</div>
<div class="action-text">健康课程</div>
</div>
</div>
</div>

<!-- 今日任务 -->
<div class="tasks-section">
<div class="section-title">✅ 今日任务</div>
<div class="task-list" id="taskList">
<!-- JS生成 -->
</div>
</div>
</div>
</div>

<!-- ========== 训练页 ========== -->
<div class="page" id="workoutPage">
<div class="workout-page">
<div class="page-header">
<div class="page-title">训练计划</div>
<div class="page-subtitle">选择适合你的训练课程</div>
</div>

<div class="category-tabs">
<div class="tab active" onclick="filterWorkout('all', this)">全部</div>
<div class="tab" onclick="filterWorkout('strength', this)">力量</div>
<div class="tab" onclick="filterWorkout('cardio', this)">有氧</div>
<div class="tab" onclick="filterWorkout('yoga', this)">瑜伽</div>
</div>

<div class="workout-list" id="workoutList">
<!-- 燃脂训练 -->
<div class="workout-item" data-category="cardio" onclick="startWorkout('全身燃脂训练', 20, 200)">
<div class="workout-thumb">🔥</div>
<div class="workout-info">
<div class="workout-name">全身燃脂训练</div>
<div class="workout-meta"><span>⏱️ 20分钟</span><span>🔥 200千卡</span><span>中级</span></div>
</div>
<div class="workout-play-btn">▶️</div>
</div>
<div class="workout-item" data-category="cardio" onclick="startWorkout('HIIT高强度间歇', 30, 350)">
<div class="workout-thumb">⚡</div>
<div class="workout-info">
<div class="workout-name">HIIT高强度间歇</div>
<div class="workout-meta"><span>⏱️ 30分钟</span><span>🔥 350千卡</span><span>高级</span></div>
</div>
<div class="workout-play-btn">▶️</div>
</div>
<div class="workout-item" data-category="cardio" onclick="startWorkout('有氧舞蹈', 25, 180)">
<div class="workout-thumb">💃</div>
<div class="workout-info">
<div class="workout-name">有氧舞蹈</div>
<div class="workout-meta"><span>⏱️ 25分钟</span><span>🔥 180千卡</span><span>初级</span></div>
</div>
<div class="workout-play-btn">▶️</div>
</div>
<div class="workout-item" data-category="cardio" onclick="startWorkout('跳绳训练', 15, 150)">
<div class="workout-thumb">⚪</div>
<div class="workout-info">
<div class="workout-name">跳绳训练</div>
<div class="workout-meta"><span>⏱️ 15分钟</span><span>🔥 150千卡</span><span>中级</span></div>
</div>
<div class="workout-play-btn">▶️</div>
</div>
<div class="workout-item" data-category="cardio" onclick="startWorkout('波比跳挑战', 10, 120)">
<div class="workout-thumb">🏃</div>
<div class="workout-info">
<div class="workout-name">波比跳挑战</div>
<div class="workout-meta"><span>⏱️ 10分钟</span><span>🔥 120千卡</span><span>高级</span></div>
</div>
<div class="workout-play-btn">▶️</div>
</div>

<!-- 力量训练 -->
<div class="workout-item" data-category="strength" onclick="startWorkout('腹肌撕裂者', 15, 120)">
<div class="workout-thumb">💪</div>
<div class="workout-info">
<div class="workout-name">腹肌撕裂者</div>
<div class="workout-meta"><span>⏱️ 15分钟</span><span>🔥 120千卡</span><span>高级</span></div>
</div>
<div class="workout-play-btn">▶️</div>
</div>
<div class="workout-item" data-category="strength" onclick="startWorkout('哑铃手臂训练', 20, 150)">
<div class="workout-thumb">🏋️</div>
<div class="workout-info">
<div class="workout-name">哑铃手臂训练</div>
<div class="workout-meta"><span>⏱️ 20分钟</span><span>🔥 150千卡</span><span>中级</span></div>
</div>
<div class="workout-play-btn">▶️</div>
</div>
<div class="workout-item" data-category="strength" onclick="startWorkout('胸肌轰炸', 25, 180)">
<div class="workout-thumb">🎯</div>
<div class="workout-info">
<div class="workout-name">胸肌轰炸</div>
<div class="workout-meta"><span>⏱️ 25分钟</span><span>🔥 180千卡</span><span>中级</span></div>
</div>
<div class="workout-play-btn">▶️</div>
</div>
<div class="workout-item" data-category="strength" onclick="startWorkout('背部力量', 30, 200)">
<div class="workout-thumb">🔙</div>
<div class="workout-info">
<div class="workout-name">背部力量</div>
<div class="workout-meta"><span>⏱️ 30分钟</span><span>🔥 200千卡</span><span>高级</span></div>
</div>
<div class="workout-play-btn">▶️</div>
</div>
<div class="workout-item" data-category="strength" onclick="startWorkout('腿部塑形', 25, 220)">
<div class="workout-thumb">🦵</div>
<div class="workout-info">
<div class="workout-name">腿部塑形</div>
<div class="workout-meta"><span>⏱️ 25分钟</span><span>🔥 220千卡</span><span>中级</span></div>
</div>
<div class="workout-play-btn">▶️</div>
</div>
<div class="workout-item" data-category="strength" onclick="startWorkout('核心稳定', 20, 140)">
<div class="workout-thumb">⭐</div>
<div class="workout-info">
<div class="workout-name">核心稳定</div>
<div class="workout-meta"><span>⏱️ 20分钟</span><span>🔥 140千卡</span><span>中级</span></div>
</div>
<div class="workout-play-btn">▶️</div>
</div>
<div class="workout-item" data-category="strength" onclick="startWorkout('全身力量', 35, 280)">
<div class="workout-thumb">💯</div>
