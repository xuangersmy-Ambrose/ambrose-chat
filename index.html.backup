}
  html += '<div class="point-item"><div class="point-value" style="color: var(--secondary);">125</div><div class="point-label">训练分钟</div></div>';
  html += '<div class="point-item"><div class="point-value" style="color: #FFD700;">680</div><div class="point-label">消耗千卡</div></div>';
