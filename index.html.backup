  { date: '2026-03-03', name: 'HIIT高强度间歇', duration: 30, calories: 350, feeling: '挑战' },
  { date: '2026-03-02', name: '哑铃手臂训练', duration: 20, calories: 150, feeling: '良好' }
];

function showDetailedWorkoutRecords() {
  var html = '<div class="page" id="detailedRecordsPage"><div class="workout-page">';
  html += '<div class="page-header"><div class="page-title">📝 训练打卡</div><div class="page-subtitle">详细记录每一次进步</div></div>';
  
  // 统计卡片
  html += '<div style="padding: 0 24px; margin-bottom: 24px;">';
  html += '<div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px;">';
  html += '<div style="background: var(--bg-card); border: 1px solid var(--border); border-radius: 16px; padding: 16px; text-align: center;">';
  html += '<div style="font-size: 24px; font-weight: 700; color: var(--primary);">' + workoutHistory.length + '</div>';
  html += '<div style="font-size: 12px; color: var(--text-secondary);">总次数</div></div>';
  html += '<div style="background: var(--bg-card); border: 1px solid var(--border); border-radius: 16px; padding: 16px; text-align: center;">';
  html += '<div style="font-size: 24px; font-weight: 700; color: var(--secondary);">' + workoutHistory.reduce((sum, r) => sum + r.duration, 0) + '</div>';
  html += '<div style="font-size: 12px; color: var(--text-secondary);">总分钟</div></div>';
  html += '<div style="background: var(--bg-card); border: 1px solid var(--border); border-radius: 16px; padding: 16px; text-align: center;">';
  html += '<div style="font-size: 24px; font-weight: 700; color: #FFD700;">' + workoutHistory.reduce((sum, r) => sum + r.calories, 0) + '</div>';
  html += '<div style="font-size: 12px; color: var(--text-secondary);">总消耗</div></div>';
  html += '</div></div>';
  
  // 记录列表
  html += '<div style="padding: 0 24px;">';
  html += '<div style="font-weight: 600; margin-bottom: 16px;">📅 打卡记录</div>';
  
  workoutHistory.forEach((record, idx) => {
    html += '<div style="background: var(--bg-card); border: 1px solid var(--border); border-radius: 16px; padding: 16px; margin-bottom: 12px;">';
    html += '<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">';
    html += '<div style="font-weight: 600;">' + record.name + '</div>';
    html += '<div style="font-size: 12px; color: var(--text-secondary);">' + record.date + '</div>';
    html += '</div>';
    html += '<div style="display: flex; gap: 16px; font-size: 13px; color: var(--text-secondary);">';
    html += '<span>⏱️ ' + record.duration + '分钟</span>';
    html += '<span>🔥 ' + record.calories + '千卡</span>';
    html += '<span>😊 ' + record.feeling + '</span>';
    html += '</div></div>';
  });
  
  html += '</div>';
  html += '<button class="btn-secondary" onclick="showPage(\'profilePage\')" style="margin: 40px 24px;">← 返回我的</button>';
  html += '</div></div>';
  
  document.body.insertAdjacentHTML('beforeend', html);
  showPage('detailedRecordsPage');
}

