// 分析情感
function analyzeEmotion(text) {
  text = text.toLowerCase();
  var scores = {};
  
  for (var emotion in emotionKeywords) {
    scores[emotion] = 0;
    var keywords = emotionKeywords[emotion];
    for (var i = 0; i < keywords.length; i++) {
      if (text.indexOf(keywords[i]) !== -1) {
        scores[emotion]++;
      }
    }
  }
  
  // 标点符号分析
  if (text.indexOf('!') !== -1 || text.indexOf('！') !== -1) {
    scores.happy += 0.5;
  }
  if (text.indexOf('?') !== -1 || text.indexOf('？') !== -1) {
    scores.confused += 0.5;
  }
  if (text.indexOf('...') !== -1 || text.indexOf('。。。') !== -1) {
    scores.sad += 0.3;
  }
  
  // 找到最高分
  var maxEmotion = 'neutral';
  var maxScore = 0;
  for (var emotion in scores) {
    if (scores[emotion] > maxScore) {
      maxScore = scores[emotion];
      maxEmotion = emotion;
    }
  }
  
  return maxEmotion;
}

// 生成AI回复
function generateResponse(userMessage) {
  var emotion = analyzeEmotion(userMessage);
  var responses = emotionResponses[emotion];
  var response = responses[Math.floor(Math.random() * responses.length)];
  
  // 个性化建议
  if (userMessage.indexOf('运动') !== -1 || userMessage.indexOf('步数') !== -1) {
    var steps = userData.todayData.steps || 0;
    response += "\n\n" + healthAdvice.exercise[0].replace('{steps}', steps);
  }
  else if (userMessage.indexOf('饮食') !== -1 || userMessage.indexOf('吃') !== -1) {
    var calories = userData.todayData.calories || 0;
    response += "\n\n" + healthAdvice.diet[0].replace('{calories}', calories);
  }
  else if (userMessage.indexOf('睡眠') !== -1 || userMessage.indexOf('睡') !== -1) {
    var sleep = userData.todayData.sleep || 0;
    var quality = sleep >= 7 ? '睡眠质量不错' : '建议多休息一下';
    response += "\n\n" + healthAdvice.sleep[0].replace('{sleep}', sleep).replace('{quality}', quality);
  }
  else if (userMessage.indexOf('水') !== -1) {
    var water = userData.todayData.water || 0;
    response += "\n\n" + healthAdvice.water[0].replace('{water}', water);
  }
  
  return { text: response, emotion: emotion };
}

// 更新情感指示器
function updateEmotionIndicator(emotion) {
  var indicator = document.getElementById('currentEmotion');
  var text = document.querySelector('.emotion-text');
  if (indicator) {
    indicator.textContent = emotionEmojis[emotion];
  }
  if (text) {
    var texts = {
      happy: 'AMBROSE和你一起开心！',
      sad: 'AMBROSE在陪着你...',
      angry: 'AMBROSE理解你的情绪',
      surprised: '哇！真的吗？',
      confused: 'AMBROSE来帮你解答',
      loving: 'AMBROSE也很感动~',
      tired: '记得休息哦',
      neutral: 'AMBROSE正在倾听...'
    };
    text.textContent = texts[emotion] || 'AMBROSE正在倾听...';
  }
}

// 添加消息到对话
function addMessage(text, isUser) {
  var container = document.getElementById('chatContainer');
  if (!container) return;
  
  var messageDiv = document.createElement('div');
  messageDiv.className = 'chat-message ' + (isUser ? 'user-message' : 'bot-message');
  
  var avatar = isUser ? (currentUser ? (currentUser.gender === 'female' ? '👩' : '👨') : '👤') : '🦞';
  var time = new Date().toLocaleTimeString('zh-CN', { hour: '2-digit', minute: '2-digit' });
  
  messageDiv.innerHTML = `
    <div class="message-avatar">${avatar}</div>
    <div class="message-content">
      <div class="message-text">${text.replace(/\n/g, '<br>')}</div>
      <div class="message-time">${time}</div>
    </div>
  `;
  
  container.appendChild(messageDiv);
  container.scrollTop = container.scrollHeight;
}

// 添加打字指示器
function addTypingIndicator() {
  var container = document.getElementById('chatContainer');
  if (!container) return null;
  
  var indicatorDiv = document.createElement('div');
  indicatorDiv.className = 'chat-message bot-message typing-message';
  indicatorDiv.innerHTML = `
    <div class="message-avatar">🦞</div>
    <div class="message-content">
      <div class="typing-indicator">
        <span></span><span></span><span></span>
      </div>
    </div>
  `;
  
  container.appendChild(indicatorDiv);
  container.scrollTop = container.scrollHeight;
  return indicatorDiv;
}

// 移除打字指示器
function removeTypingIndicator() {
  var indicator = document.querySelector('.typing-message');
  if (indicator) {
    indicator.remove();
  }
}

// 发送消息
function sendChatMessage() {
  var input = document.getElementById('chatInput');
  if (!input) return;
  
  var message = input.value.trim();
  if (!message) return;
  
  // 添加用户消息
  addMessage(message, true);
  input.value = '';
  
  // 分析情感并更新指示器
  var emotion = analyzeEmotion(message);
  updateEmotionIndicator(emotion);
  
  // 显示打字指示器
  var typingIndicator = addTypingIndicator();
  
  // 延迟回复（模拟思考）
  setTimeout(function() {
    removeTypingIndicator();
    var response = generateResponse(message);
    addMessage(response.text, false);
    updateEmotionIndicator(response.emotion);
    
    // 保存对话历史
    saveChatHistory(message, response.text);
  }, 1000 + Math.random() * 1000);
}

// 快捷消息
function sendQuickMessage(message) {
  var input = document.getElementById('chatInput');
  if (input) {
    input.value = message;
    sendChatMessage();
  }
}

// 保存对话历史
function saveChatHistory(userMsg, botMsg) {
  if (!userData.chatHistory) {
    userData.chatHistory = [];
  }
  userData.chatHistory.push({
    time: new Date().toISOString(),
    user: userMsg,
    bot: botMsg
  });
  // 只保留最近50条
  if (userData.chatHistory.length > 50) {
    userData.chatHistory.shift();
  }
  saveData();
}

// ==================== Push 通知功能 ====================
const VAPID_PUBLIC_KEY = 'BEl62iTMYFb0-bwI0fE8x5S_J7R4vGz5lJz5lJz5lJz5lJz5lJz5lJz5lJz5lJz5lJz5lJz5lJz5lJz5lJz'; // 实际使用时替换

async function requestNotificationPermission() {
  if (!('Notification' in window)) {
    showToast('❌ 浏览器不支持通知');
    return false;
  }
  
  const permission = await Notification.requestPermission();
  if (permission === 'granted') {
    showToast('✅ 通知权限已开启');
    return true;
  }
  showToast('⚠️ 通知权限被拒绝');
  return false;
}

async function subscribeToPushNotifications() {
  try {
    const hasPermission = await requestNotificationPermission();
    if (!hasPermission) return;
    
    const registration = await navigator.serviceWorker.ready;
    const subscription = await registration.pushManager.subscribe({
      userVisibleOnly: true,
      applicationServerKey: urlBase64ToUint8Array(VAPID_PUBLIC_KEY)
    });
    
    // 保存到本地存储（实际应发送到服务器）
    localStorage.setItem('pushSubscription', JSON.stringify(subscription));
    showToast('✅ 推送订阅成功');
    
  } catch (error) {
    console.error('Push subscription failed:', error);
    showToast('❌ 订阅失败');
  }
}

function urlBase64ToUint8Array(base64String) {
  const padding = '='.repeat((4 - base64String.length % 4) % 4);
  const base64 = (base64String + padding).replace(/\-/g, '+').replace(/_/g, '/');
  const rawData = atob(base64);
  const outputArray = new Uint8Array(rawData.length);
  for (let i = 0; i < rawData.length; ++i) {
    outputArray[i] = rawData.charCodeAt(i);
  }
  return outputArray;
}

// ==================== 后台同步功能 ====================
async function registerBackgroundSync(tag) {
  if ('sync' in ServiceWorkerRegistration.prototype) {
    try {
      const registration = await navigator.serviceWorker.ready;
      await registration.sync.register(tag);
      console.log('[App] Background sync registered:', tag);
    } catch (error) {
      console.warn('[App] Background sync failed:', error);
    }
  }
}

// ==================== 初始化 ====================
window.onload = function() {
  // 注册 Service Worker (PWA支持)
  if ('serviceWorker' in navigator) {
    navigator.serviceWorker.register('/sw.js')
      .then(registration => {
        console.log('[App] SW registered:', registration.scope);
      })
      .catch(error => {
        console.log('[App] SW registration failed:', error);
      });
  }
  
  // 显示骨架屏
  showSkeletonLoader();
  
  setTimeout(function() {
    hideSkeletonLoader();
    
    var saved = localStorage.getItem('ambroseUser');
    if (saved) {
      currentUser = JSON.parse(saved);
      loadData();
      showPage('homePage');
      if (typeof updateHomePage === 'function') updateHomePage();
      if (typeof updateProfilePage === 'function') updateProfilePage();
      // 检查是否显示新手引导
      setTimeout(checkOnboarding, 1000);
    } else {
      showPage('loginPage');
      if (typeof switchMode === 'function') switchMode('boss');
    }
  }, 500);
};
</script>

